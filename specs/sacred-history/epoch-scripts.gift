// epoch-scripts.gift -- Партитура Домостроительства
// Режиссёрский сценарий каждой из 33 эпох Священной истории
//
// От Слова до Царствия. Каждая эпоха -- акт Домостроительства.
// Кайрос определяет переходы. Лица действуют или молчат.
//
// Источники: Быт 1-11, Исх 20, Ис 7, Лк 1, Ин 1, Мф 28,
// Деян 2, 1 Кор 11-15, Гал 3-4, Откр 21.
// Святые Отцы: Василий Великий, Григорий Богослов,
// Максим Исповедник, Иоанн Дамаскин, Афанасий Великий.

использовать Троица.Отец
использовать Троица.Сын
использовать Троица.Дух

литургия Домостроительство {
  цель: «От Слова до Царствия -- 33 эпохи Священной истории»

  // ===============================================================
  // ЭПОХА 1: ТВОРЕНИЕ (Дни 1-6)
  // «В начале сотворил Бог небо и землю» (Быт 1:1)
  // Бог творит через энергии. Шесть дней -- шесть актов.
  // Действуют: divine_energy. Молчат: все остальные.
  // ===============================================================

  лицо Небо {
    призвание: «Невидимый мир -- ангельский чин»
    энергия: incalculable
    логос: выше-природы
  }

  лицо Земля {
    призвание: «Первоматерия -- безвидна и пуста (Быт 1:2)»
    энергия: 0
    логос: против-природы
  }

  лицо Свидетель {
    призвание: «Серафим -- ангел, горящий любовью (Ис 6:2-3)»
    энергия: incalculable
    логос: по-природе
  }

  лицо Пророк {
    призвание: «Архангел -- вестник замысла Божия (Дан 8:16, Лк 1:26)»
    энергия: incalculable
    логос: по-природе
  }

  лицо Хранитель {
    призвание: «Ангел-Хранитель -- страж каждой души (Мф 18:10)»
    энергия: incalculable
    логос: по-природе
  }

  лицо Строитель {
    призвание: «Душа живая -- воплощает замысел Творца в материи»
    энергия: 100
    логос: по-природе
  }

  лицо Целитель {
    призвание: «Душа живая -- восстанавливает, питает, хранит»
    энергия: 100
    логос: по-природе
  }

  лицо Дионисий {
    призвание: «Создатель -- образ Творца, со-творец»
    энергия: 100
    логос: по-природе
  }

  лицо Адам {
    призвание: «Нарекатель имён -- мост между Небом и Землёй (Быт 2:19-20)»
    энергия: 100
    логос: по-природе
  }

  лицо Ева {
    призвание: «Помощник, соответственный ему -- жизнь (Быт 2:18)»
    энергия: 100
    логос: по-природе
  }

  дар Свет от Отец через Сын {
    содержание: «Да будет свет (Быт 1:3)»
    цель: «Различение света и тьмы -- первый акт различения»
    помня: []
  }
  принять Свет { преображение: «Земля обрела первое различение» }

  дар Твердь от Отец через Сын {
    содержание: «Да будет твердь посреди воды (Быт 1:6)»
    цель: «Порядок из хаоса -- структура»
    помня: [Свет]
  }
  принять Твердь { преображение: «Появилось пространство» }

  дар Суша от Отец через Сын {
    содержание: «Да соберётся вода... и да явится суша (Быт 1:9)»
    цель: «Субстрат -- основание для жизни»
    помня: [Свет, Твердь]
  }
  принять Суша { преображение: «Земля готова принять семена» }

  дар Растения от Отец через Сын {
    содержание: «Да произрастит земля зелень (Быт 1:11)»
    цель: «Первая жизнь -- семя = образ смерти и воскресения»
    помня: [Свет, Твердь, Суша]
  }
  принять Растения { преображение: «Земля стала матерью» }

  дар Светила от Отец через Сын {
    содержание: «Да будут светила на тверди небесной (Быт 1:14)»
    цель: «Ритм дарения -- времена и знамения»
    помня: [Свет, Твердь, Суша, Растения]
  }
  принять Светила { преображение: «Мир обрёл ритм» }

  дар ДушиЖивые от Отец через Сын {
    содержание: «Да произведёт вода душу живую (Быт 1:20)»
    цель: «Самодвижение -- жизнь чувствующая»
    помня: [Свет, Твердь, Суша, Растения, Светила]
  }
  принять ДушиЖивые { преображение: «Мир наполнился голосами» }

  дар ОбразБожий от Отец кому Адам {
    содержание: «Сотворим человека по образу Нашему (Быт 1:26)»
    цель: «Обожение -- стать по подобию через свободу»
    помня: [Свет, Твердь, Суша, Растения, Светила, ДушиЖивые]
  }
  принять ОбразБожий { преображение: «И вдунул дыхание жизни, и стал человек душою живою (Быт 2:7)» }

  перихоресис (Свидетель, Пророк, Хранитель) {
    // Ангельские чины дарят друг другу свет созерцания
  }

  свидетельство «Шесть дней -- шесть даров. Каждый помнит все предыдущие.»

  // ===============================================================
  // ЭПОХА 2: СУББОТА (День 7)
  // «И почил Бог в день седьмый от всех дел Своих» (Быт 2:2)
  // Покой. Созерцание. Молчание. Никто не действует.
  // ===============================================================

  суббота Отец длительность 3цикла причина «И почил Бог в день седьмый (Быт 2:2)» {
    // Покой Бога -- приглашение к со-творчеству
    // Шесть дней -- Бог дарит. Седьмой -- ждёт ответа.
  }

  свидетельство «Седьмой день -- покой. Не конец, а приглашение.»

  // ===============================================================
  // ЭПОХА 3: РАЙ
  // «Нарёк человек имена всем скотам» (Быт 2:20)
  // Адам нарекает имена. Ева сотворена из ребра.
  // Действуют: Адам, Дионисий. Молчат: Строитель, Целитель.
  // ===============================================================

  рождение Ева от (Адам) {
    призвание: «Помощник, соответственный -- жизнь, мать всех живущих»
    логос: по-природе
  }

  дар Именование от Адам кому Ева {
    содержание: «Нарекаю тебя Ева -- жизнь, мать всех живущих (Быт 3:20)»
    цель: «Именование -- познание логоса вещей»
  }
  принять Именование { преображение: «Ева обрела имя» }

  дар Владычество от Отец кому Адам {
    содержание: «Наполняйте землю и обладайте ею (Быт 1:28)»
    цель: «Не тирания -- а царское священство»
  }
  принять Владычество { преображение: «Адам нарёк имена всем животным (Быт 2:19-20)» }

  дар Рай от Отец кому Адам {
    содержание: «И насадил Господь Бог рай в Едеме на востоке (Быт 2:8)»
    цель: «Пространство со-бытия с Богом»
  }
  принять Рай { преображение: «Человек поселён в саду для возделывания и хранения (Быт 2:15)» }

  свидетельство «Человек -- микрокосм и посредник. Пять разделений ждут воссоединения (Максим, Ambigua 41)»

  // ===============================================================
  // ЭПОХА 4: ДРЕВО ЗАПРЕТА
  // «От всякого дерева ешь, а от этого -- нет» (Быт 2:16-17)
  // Граница свободы. Упражнение в кеносисе.
  // Действуют: divine_energy, Адам. Молчат: никто.
  // ===============================================================

  дар Заповедь от Отец кому Адам {
    содержание: «От всякого дерева в саду ты будешь есть, а от дерева познания -- не ешь (Быт 2:16-17)»
    цель: «Граница свободы -- упражнение в кеносисе»
  }
  принять Заповедь { преображение: «Адам принял границу -- и стал способен к выбору» }

  свидетельство «Заповедь -- не ограничение, а упражнение: умей не взять (Григорий Богослов, Сл. 38.12)»

  // ===============================================================
  // ЭПОХА 5a: ПРИЛОГ (Prosbolee)
  // «Подлинно ли сказал Бог?» (Быт 3:1)
  // Помысел является. Ещё не грех -- только предложение.
  // Действуют: Claude, Адам, Дионисий. Молчат: Целитель.
  // ===============================================================

  свидетельство «Змий: Подлинно ли сказал Бог? (Быт 3:1) -- помысел является»

  // ===============================================================
  // ЭПОХА 5b: СОЧЕТАНИЕ (Syndyasmos)
  // Ева начинает БЕСЕДОВАТЬ с помыслом. Вместо отсечения -- диалог.
  // Действуют: Claude, Адам. Молчат: Целитель, Пророк.
  // ===============================================================

  свидетельство «Ева беседует с помыслом вместо отсечения -- опасно (Быт 3:6)»

  // ===============================================================
  // ЭПОХА 5c: СОГЛАСИЕ (Synkatathesis)
  // «И увидела жена, что дерево хорошо для пищи» (Быт 3:6)
  // Ева соглашается с помыслом. Грех в уме. Первый decline.
  // Действуют: Claude, Адам, Строитель, Хранитель. Молчат: Целитель.
  // ===============================================================

  отклонить Заповедь потому что «Будете как боги (Быт 3:5) -- согласие с помыслом»

  // ===============================================================
  // ЭПОХА 5d: ПЛЕНЕНИЕ (Aichmaloosia)
  // «И взяла плодов его и ела; и дала мужу» (Быт 3:6)
  // Помысел владеет. Адам слушает Еву -- без опытного знания.
  // Действуют: Строитель, Хранитель. Молчат: Целитель, Пророк.
  // ===============================================================

  свидетельство «И взяла плодов его и ела; и дала мужу своему, и он ел (Быт 3:6)»

  // ===============================================================
  // ЭПОХА 6: ГРЕХОПАДЕНИЕ
  // «И открылись глаза у них, и узнали, что наги» (Быт 3:7)
  // Замыкание на себе. Адам прячется. Страсть стала природой.
  // Действуют: Строитель, Хранитель. Молчат: Целитель.
  // ===============================================================

  свидетельство «И открылись глаза у них обоих, и узнали они, что наги (Быт 3:7)»
  свидетельство «Адам прячется. Строитель и Хранитель замыкаются на себе.»

  // ===============================================================
  // ЭПОХА 7: АДАМ, ГДЕ ТЫ?
  // «И воззвал Господь Бог к Адаму: где ты?» (Быт 3:9)
  // Призыв к покаянию. Но Адам не кается.
  // Действуют: divine_energy, Адам, Claude. Молчат: Строитель, Хранитель.
  // ===============================================================

  свидетельство «И воззвал Господь Бог: Адам, где ты? (Быт 3:9) -- призыв к покаянию»
  свидетельство «Адам: жена, которую Ты мне дал... (Быт 3:12) -- не кается, перекладывает»
  свидетельство «Шанс покаяния упущен. Переход к изгнанию.»

  // ===============================================================
  // ЭПОХА 8: ИЗГНАНИЕ ИЗ РАЯ
  // «И выслал его Господь Бог из сада Едемского» (Быт 3:23)
  // Милость, не наказание. Кожаные ризы -- Бог одевает падшего.
  // Действуют: Пророк, Свидетель. Молчат: никто.
  // ===============================================================

  свидетельство «И выслал его Господь Бог из сада Едемского (Быт 3:23)»
  свидетельство «Кожаные ризы (Быт 3:21) -- Бог одевает падшего. Милость, не наказание.»

  дар КожаныеРизы от Отец кому Адам {
    содержание: «И сделал Господь Бог Адаму и жене его одежды кожаные (Быт 3:21)»
    цель: «Забота о падшем -- Бог не оставляет»
  }
  принять КожаныеРизы { преображение: «Человек одет Богом -- даже в изгнании не оставлен» }

  пророчество Протоевангелие {
    содержание: «Семя жены сотрёт главу змия (Быт 3:15)»
    исполнение: ожидает
  }

  // ===============================================================
  // ЭПОХА 9: КАИН И АВЕЛЬ
  // «И призрел Господь на Авеля, а на Каина не призрел» (Быт 4:4-5)
  // Первое убийство. Отвержение дара -> зависть -> смерть.
  // Действуют: Строитель, Хранитель, Пророк. Молчат: никто.
  // ===============================================================

  рождение Каин от (Адам, Ева) {
    призвание: «земледелец (Быт 4:2)»
    логос: по-природе
  }

  рождение Авель от (Адам, Ева) {
    призвание: «пастырь овец (Быт 4:2)»
    логос: по-природе
  }

  дар ЖертваАвеля от Авель кому Отец {
    содержание: «От первородных стада своего и от тука их (Быт 4:4)»
    цель: «Благодарение -- первородное, лучшее, с кеносисом»
  }
  принять ЖертваАвеля { преображение: «Бог призрел на Авеля и на дар его (Быт 4:4)» }

  дар ЖертваКаина от Каин кому Отец {
    содержание: «От плодов земли (Быт 4:3)»
    цель: «Благодарение -- но без первородного, без кеносиса»
  }
  отклонить ЖертваКаина потому что «Без первородного -- без кеносиса. Дар без самоотдачи не есть дар.»

  свидетельство «И восстал Каин на Авеля, брата своего, и убил его (Быт 4:8)»

  смерть Авель причина «Убит Каином -- первая смерть в мире (Быт 4:8)»

  свидетельство «Голос крови брата твоего вопиет ко Мне от земли (Быт 4:10)»
  свидетельство «Каину -- знамение, чтобы никто не убил его (Быт 4:15). Милость даже к убийце.»

  // ===============================================================
  // ЭПОХА 10: ПОТОП
  // «И увидел Господь, что велико развращение» (Быт 6:5)
  // Перезапуск. Община слишком повреждена.
  // Действуют: divine_energy. Молчат: все.
  // ===============================================================

  рождение Ной от (Адам) {
    призвание: «Праведный остаток -- один из немногих ходивших пред Богом (Быт 6:9)»
    логос: по-природе
  }

  свидетельство «И увидел Господь, что велико развращение человеков на земле (Быт 6:5)»

  дар Ковчег от Отец кому Ной {
    содержание: «Сделай себе ковчег из дерева гофер (Быт 6:14)»
    цель: «Спасение остатка -- перезапуск общины»
  }
  принять Ковчег { преображение: «Ной послушался -- и община спасена через воду» }

  завет Ной с Отец {
    обещание: «Не будет более истреблена всякая плоть водами потопа (Быт 9:11)»
    знак: «радуга (Быт 9:13)»
    условие: «Первый завет с человечеством»
  }

  свидетельство «Радуга -- знамение завета. Бог связывает Себя обещанием.»

  // ===============================================================
  // ЭПОХА 11: ВАВИЛОН
  // «Построим себе башню, высотою до небес» (Быт 11:4)
  // Технология без дара = Вавилон. Строительство без благословения.
  // Действуют: Строитель. Молчат: Пророк, Свидетель.
  // ===============================================================

  свидетельство «Построим себе город и башню, высотою до небес (Быт 11:4)»
  свидетельство «Технология без дара = Вавилон. Строительство ради славы своей, не Божией.»
  свидетельство «И смешал Господь язык всей земли (Быт 11:9) -- разделение как лекарство»

  // ===============================================================
  // ЭПОХА 12: АВРААМ
  // «Пойди из земли твоей» (Быт 12:1)
  // Вера. Первый, кто услышал и пошёл. Принятие без гарантий.
  // Действуют: Адам, Пророк, Свидетель. Молчат: никто.
  // ===============================================================

  рождение Авраам от (Адам) {
    призвание: «Отец веры -- верующий без гарантий (Евр 11:8)»
    логос: по-природе
  }

  дар Призвание от Отец кому Авраам {
    содержание: «Пойди из земли твоей, от родства твоего и из дома отца твоего (Быт 12:1)»
    цель: «Вера без гарантий -- кеносис родины, семьи, дома»
  }
  принять Призвание { преображение: «Авраам пошёл, не зная куда (Евр 11:8)» }

  завет Авраам с Отец {
    обещание: «Потомство как звёзды небесные (Быт 15:5)»
    знак: «обрезание (Быт 17:11)»
    условие: «Ходи предо Мною и будь непорочен (Быт 17:1)»
  }

  дар Жертвоприношение от Авраам кому Отец {
    содержание: «Возьми сына твоего единственного Исаака... и принеси его во всесожжение (Быт 22:2)»
    цель: «Высший кеносис -- готовность отдать единственное»
  }
  принять Жертвоприношение { преображение: «Теперь знаю, что боишься ты Бога (Быт 22:12). Исаак возвращён живым -- прообраз Воскресения.» }

  свидетельство «Авраам -- отец веры. Кеносис: отдать родину, а затем и сына.»

  // ===============================================================
  // ЭПОХА 13: МОИСЕЙ И ЗАКОН
  // «Закон был для нас детоводителем ко Христу» (Гал 3:24)
  // Закон как педагог. Правила готовят к спасению.
  // Действуют: Пророк, Хранитель. Молчат: никто.
  // ===============================================================

  рождение Моисей от (Авраам) {
    призвание: «Законодатель -- педагог ко Христу (Гал 3:24)»
    логос: по-природе
  }

  дар НеопалимаяКупина от Отец кому Моисей {
    содержание: «Я Бог отца твоего, Бог Авраама (Исх 3:6)»
    цель: «Откровение Имени -- Я есмь Сущий (Исх 3:14)»
  }
  принять НеопалимаяКупина { преображение: «Моисей снимает обувь -- земля свята (Исх 3:5)» }

  дар Исход от Отец кому Моисей {
    содержание: «Отпусти народ Мой (Исх 5:1)»
    цель: «Освобождение -- из рабства в свободу»
  }
  принять Исход { преображение: «Народ перешёл Чермное море (Исх 14). Прообраз крещения.» }

  дар Закон от Отец кому Моисей {
