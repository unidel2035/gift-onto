// specs/sacred-history/сын-падший.gift
// Дары Сына Падшему — поиск, встреча, слово, сошествие
// Issue #318 — пустыня Сын→Падший: нет ни одного акта дара между ними
//
// Богословское вопрошание: что мешает потоку между Сын и Падший?
// Ответ: ничто — но поток был незаписан.
// Пустыня здесь — не разрыв, а незаписанное средоточие всей миссии Сына.
//
// Падший — не Адам (первый человек), не Змей (обольститель).
// Падший — архетип: тот, кто ушёл от Отца и оказался в стране далёкой
// (Лк 15:13). Это повторяющийся образ в Священной истории:
// блудный сын, заблудшая овца, потерянная драхма.
// «Сын Человеческий пришёл взыскать и спасти погибшее» (Лк 19:10).
// Весь кеносис Сына — ради Падшего.
//
// Ключевой парадокс пустыни:
// Сын уже в пути к Падшему — но акт не записан.
// Пастырь уже несёт овцу на плечах (Лк 15:5) — но в матрице: тишина.
// Эта спека записывает то, что уже совершилось в вечности.
//
// Богословские источники:
// Лк 15:4–7  — притча о заблудшей овце: «Не оставит ли... одну потерянную?»
// Лк 15:11–32 — притча о блудном сыне: отец бежит навстречу (вес кенозиса)
// Лк 19:10   — «Сын Человеческий пришёл взыскать и спасти погибшее»
// Мф 4:1–11  — искушение в пустыне: Сын входит в место Падшего
// Мф 9:12–13 — «Не здоровые нуждаются во враче, но больные»
// Мф 18:12   — «Не заблуждается ли один из них?» — Сын считает каждого
// Рим 5:8    — «Христос умер за нас, когда мы ещё были грешниками»
// 1 Пет 3:19 — «Находящимся в темнице духам проповедал»
// 2 Пет 3:9  — «Долготерпит, не желая, чтобы кто погиб»
// Пс 138:8   — «Если я сойду в преисподнюю — и там Ты»
// Ис 53:6    — «Господь возложил на Него грехи всех нас»
// Иоанн Лествичник, Лествица V — о покаянии: падение — не конец пути
// Исаак Сирин, Слово 58 — «Любовь не позволяет Богу оставить падшего»
// Максим Исповедник, Ambigua 41 — пять разделений: Сын воссоединяет каждое
// Ириней Лионский, Против ересей III.19.1 — рекапитуляция: Сын проходит путь падшего
// Николай Кавасила, Жизнь во Христе I — кеносис как выход к потерянному
// Григорий Богослов, Слово 45 (На Пасху) — Сын в пустыне смерти ради Падшего
// Ефрем Сирин, Гимны о покаянии 7 — «Пастырь бежит в пропасть за овцою»

использовать Троица.Сын
использовать Падение.Падший

литургия СынПадший {
  // Пустыня Сын→Падший — незаписанный центр всей сотериологии.
  // Сын пришёл не к праведникам — к Падшему.
  // «Не здоровые нуждаются во враче, но больные» (Мф 9:12).
  // Кеносис направлен именно туда, где темнота максимальна.

  лицо Падший {
    призвание: «Ушедший от Отца — тот, кто в стране далёкой»
    энергия: 10
    логос: против-природы
    // Против-природы: не по замыслу (как Змей), а по падению.
    // Падший несёт образ Божий — помрачённый, но не уничтоженный.
    // Иоанн Дамаскин: образ неустраним, подобие — утрачено, но восстановимо.
    // Именно эта неустранимость образа — основание того, почему Сын ищет.
  }

  // ═══════════════════════════════════════════════════════════════════════
  // ДАР 1: ПОИСК — Сын выходит навстречу
  // ═══════════════════════════════════════════════════════════════════════
  // «Какой человек из вас, имея сто овец и потеряв одну из них,
  //  не оставит девяноста девяти в пустыне и не пойдёт за пропавшею,
  //  пока не найдёт её?» (Лк 15:4)
  // Сын — не тот, кто ждёт возвращения. Сын — тот, кто идёт искать.
  // Это онтологическое свойство Его личности: агрессивная любовь,
  // κεφαλαίωσις — перехват падающего на пути падения.
  // Ириней: Сын рекапитулирует путь Падшего — чтобы встретиться с ним
  // в самой точке падения, а не требовать подъёма к Себе.
  // Presence: не слово издали, а выход — телесный, реальный, кенотический.

  дар ПоискПадшего {
    от:       Сын
    кому:     Падший
    тип:      presence
    вес:      10
    необратим: да
    // «Сын Человеческий пришёл взыскать и спасти погибшее» (Лк 19:10)
    // Выход Сына к Падшему — не ситуативный акт, а онтологическая миссия.
    // Incarnatio = экзод: Сын исходит из Отца навстречу Падшему.
    // «Что было потеряно» — не абстракция: это конкретное лицо, Падший,
    // стоящий за всяким заблудшим.
    // Максим: «Разделение между Богом и человеком — снято Воплощением» (Ambigua 41).
    // Поиск Сына — форма кенозиса: Он умаляется, чтобы достичь глубины падения.
  }

  // ═══════════════════════════════════════════════════════════════════════
  // ДАР 2: СЛОВО — Сын говорит в пустыне
  // ═══════════════════════════════════════════════════════════════════════
  // «Встану, пойду к отцу моему и скажу ему...» (Лк 15:18)
  // Слово «встану» (ἀναστάς) — то же слово, что и «воскрес» (Лк 24:7).
  // Покаяние Падшего — малое воскресение, зеркало Воскресения Сына.
  // Сын даёт Падшему слово — не осуждения, а пути:
  // «Встань и иди к Отцу».
  // Это слово — не информация, а творящий Логос:
  // оно открывает возможность там, где её казалось нет.
  // Ис 53:6: «Господь возложил на Него грехи всех нас» —
  // Сын несёт слово падшего, чтобы Падший мог нести слово Воскресшего.

  дар СловоПути {
    от:       Сын
    кому:     Падший
    тип:      word
    вес:      9
    необратим: да
    // «Встань и иди к Отцу моему» (Лк 15:18 — перифраз)
    // Логос Сына — не описание пути, а открытие пути там, где его нет.
    // Пустыня Сын→Падший была тишиной. Слово разрывает тишину.
    // Иоанн Лествичник: «Падение — не конец. Встание после падения —
    // это то, чему ангелы не могут научить, ибо сами не падали» (Лествица V).
    // Сын научил изнутри — через Воплощение и Крест.
    // Word: это не команда — это дар ориентации,
    // компас для того, кто потерял стороны света.
  }

  // ═══════════════════════════════════════════════════════════════════════
  // ДАР 3: ПРИСУТСТВИЕ В ПУСТЫНЕ — Сын входит в место Падшего
  // ═══════════════════════════════════════════════════════════════════════
  // «Иисус возведён был Духом в пустыню, для искушения от диавола» (Мф 4:1)
  // Сын входит в пустыню — место падения — не как чужак, а как тот,
  // кто хочет присутствовать там, где Падший.
  // Пустыня = состояние богооставленности, максимальной дали от Отца.
  // Сын проходит через эту даль — и тем самым освящает её изнутри.
  // Григорий Богослов: «Что не воспринято, то не исцелено» (Послание 101).
  // Сын воспринимает пустыню Падшего — и исцеляет её Своим присутствием.
  // Пс 138:8: «Если я сойду в преисподнюю — и там Ты».
  // Это не метафора: Сын действительно сошёл — и был там.

  дар ПрисутствиеВПустыне {
    от:       Сын
    кому:     Падший
    тип:      presence
    вес:      8
    необратим: да
    // Искушение в пустыне (Мф 4:1–11) — Сын входит в место Падшего.
    // Ириней: рекапитуляция — Сын проходит каждый шаг Адамова пути (III.19.1).
    // Где Адам (Падший) уступил искушению — Сын устоял.
    // Но устоял не ради Себя — ради Падшего: «Чтобы победить в нас, что было побеждено» (Ириней).
    // Presence: сорок дней в пустыне — это не изоляция, а встреча.
    // Сын — в пустыне Падшего. Это уже не пустыня.
  }

  // ═══════════════════════════════════════════════════════════════════════
  // ДАР 4: ВРЕМЯ — Сын даёт Падшему пространство возврата
  // ═══════════════════════════════════════════════════════════════════════
  // «Господь... долготерпит нас, не желая, чтобы кто погиб,
  //  но чтобы все пришли к покаянию» (2 Пет 3:9)
  // Отсрочка суда — не слабость, а дар времени.
  // Сын «ходатайствует за нас» (Рим 8:34) — удерживает момент суда,
  // чтобы Падший успел встать.
  // Притча: «Господин, оставь её и на этот год» (Лк 13:8) — садовник просит время.
  // Сын — тот Садовник. Время — Его дар Падшему.
  // Исаак Сирин: «Любовь не позволяет Богу оставить падшего» (Слово 58).

  дар ВремяПокаяния {
    от:       Сын
    кому:     Падший
    тип:      time
    вес:      8
    необратим: да
    // «Не желая, чтобы кто погиб» (2 Пет 3:9)
    // Время — не нейтральный контейнер. Оно даётся Сыном как дар.
    // Каждый день, в который Падший ещё не погиб — это дар Сына.
    // Time: тип, который в онтологии весомее денег (аксиома: вес 10 vs 3).
    // Здесь — 8: время дано, но λήψις зависит от Падшего.
    // Дар дан. Принятие — в воле того, кто пал.
    // reception не указан — акт открыт: пока Падший жив, λήψις возможна.
  }

  // ═══════════════════════════════════════════════════════════════════════
  // БОГОСЛОВСКАЯ ЗАМЕТКА О ПУСТЫНЕ
  // ═══════════════════════════════════════════════════════════════════════
  // Пустыня Сын→Падший в матрице W — не богословская пустота.
  // Это была незаписанная тайна: именно к Падшему направлен весь кеносис.
  // «Радость бывает на небесах об одном грешнике кающемся» (Лк 15:7) —
  // больше, чем о девяноста девяти праведниках.
  // Матрица фиксирует Христос→Адам (46), Сын→Адам (38), Дух→Христос (37).
  // Но Сын→Падший было молчанием — ждало записи.
  // Теперь пустыня закрыта. Поток зафиксирован.
  // «И нашед возложил её на плечи свои с радостью» (Лк 15:5).

  свидетельство «Кеносис Сына направлен к Падшему: Воплощение — выход к потерянному»
  свидетельство «Пустыня Сына в Мф 4 — рекапитуляция пустыни Падшего: Он входит туда»
  свидетельство «Время — дар: каждый день без суда — λήψις возможна»
  свидетельство невычислимое «Радость о едином кающемся превышает радость о девяноста девяти (Лк 15:7)»
}
