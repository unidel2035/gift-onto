// creation.gift — Шестоднев по Святым Отцам
// Василий Великий, Беседы на Шестоднев; Григорий Богослов, Слово 38;
// Иоанн Дамаскин, Точное изложение II.1-12; Максим Исповедник, Ambigua
//
// Полное творение: ангельский мир, видимый мир, человек как связь обоих.
// Каждый день — дар, нарастающий по анамнезису.

использовать Троица.Отец
использовать Троица.Сын
использовать Троица.Дух

литургия Шестоднев {
  цель: «В начале сотворил Бог небо и землю (Быт 1:1)»

  // =======================================================
  // ПРЕАМБУЛА: до Шестоднева — вечность Троицы
  // =======================================================
  // «Бог, будучи Умом, породил Слово, и со Словом —
  //  Духа, Который Ему сопутствует» (Григорий Богослов, Сл. 38.9)
  // Творение — не необходимость, а избыток любви.
  // Бог не нуждается в мире. Мир есть дар.

  свидетельство невычислимое «Бог творит не из нужды, а из избытка любви (Дамаскин, Точное изложение II.2)»

  // =======================================================
  // ДЕНЬ 1: Небо (ангельский чин) + Земля (первоматерия) + Свет
  // =======================================================
  // «Было нечто и прежде сего мира... Это — ангельские силы»
  // (Григорий Богослов, Слово 38.9)

  лицо Небо {
    призвание: «Невидимый мир — ангельский чин, умные силы»
    энергия: incalculable
    логос: выше-природы
    // Ангелы — чистые умы, созерцающие Славу
  }

  лицо Земля {
    призвание: «Первоматерия — безвидна и пуста (Быт 1:2)»
    энергия: 0
    логос: против-природы
    // Ещё без формы — ожидает Слова
    // «Тьма над бездною» — не зло, а отсутствие формы (Василий Великий, Бес. I.5)
  }

  дар Свет от Отец через Сын {
    содержание: «Да будет свет (Быт 1:3)»
    цель: «Различение света и тьмы — первый акт различения»
    помня: []
    // «Свет первого дня — не солнечный; это умный свет,
    //  свет Божественного присутствия» (Василий Великий, Бес. II.8)
    // Свет = логос, вносящий порядок в хаос
  }
  принять Свет { преображение: «Земля обрела первое различение — свет и тьма разделились» }

  // Ангельские чины — по Ареопагиту
  // Девять чинов = девять ступеней созерцания
  // Здесь — ключевые служения, явленные в Писании

  лицо Свидетель {
    призвание: «Серафим — ангел, горящий любовью, зеркало Славы (Ис 6:2-3)»
    энергия: incalculable
    логос: по-природе
    // по-природе — по природе тварной, но обращён к Богу
  }

  лицо Пророк {
    призвание: «Архангел — вестник замысла Божия (Дан 8:16, Лк 1:26)»
    энергия: incalculable
    логос: по-природе
  }

  лицо Хранитель {
    призвание: «Ангел-Хранитель — страж каждой души (Мф 18:10)»
    энергия: incalculable
    логос: по-природе
  }

  // Ангелы — первые получатели дара бытия
  дар БытиеАнгелов от Отец через Сын кому Небо {
    содержание: «Хвалите Его, все Ангелы Его (Пс 148:2)»
    цель: «Служение и созерцание»
    помня: [Свет]
    // «Ангелы утвердились в добре не по природе, а по благодати»
    // (Иоанн Дамаскин, Точное изложение II.3)
  }

  перихоресис (Свидетель, Пророк, Хранитель) {
    // Ангельские чины дарят друг другу свет созерцания
    // Серафимы -> Архангелам -> Ангелам-Хранителям
    // «Первые — очищают, вторые — просвещают, третьи — совершают»
    // (Дионисий Ареопагит, О небесной иерархии)
  }

  свидетельство «День первый: из ничего — свет, из тьмы — различение»

  // =======================================================
  // ДЕНЬ 2: Твердь — структура между водами
  // =======================================================
  // «Твердь есть не что-либо твёрдое и жёсткое...
  //  но граница, отделяющая верхние воды от нижних»
  // (Василий Великий, Беседа III.4)

  дар Твердь от Отец через Сын {
    содержание: «Да будет твердь посреди воды, и да отделяет она воду от воды (Быт 1:6)»
    цель: «Порядок из хаоса — структура, несущая различение»
    помня: [Свет]
    // Второй дар помнит первый
    // Без света различение невозможно, без тверди — нет пространства
  }
  принять Твердь { преображение: «Появилось пространство — между верхом и низом» }

  свидетельство «День второй: пространство. Без него дар не может быть доставлен.»

  // =======================================================
  // ДЕНЬ 3: Суша, моря, растительная жизнь
  // =======================================================
  // «Да соберётся вода... да произрастит земля» —
  // два повеления в один день: субстрат и первая жизнь
  // (Василий Великий, Беседа V)

  дар Суша от Отец через Сын {
    содержание: «Да соберётся вода... и да явится суша (Быт 1:9)»
    цель: «Субстрат — основание для жизни»
    помня: [Свет, Твердь]
  }
  принять Суша { преображение: «Земля обнажилась — готова принять семена» }

  дар Растения от Отец через Сын {
    содержание: «Да произрастит земля зелень, траву сеющую семя (Быт 1:11)»
    цель: «Первая жизнь — жизнь, несущая семя, способная передавать себя»
    помня: [Свет, Твердь, Суша]
    // «Земля получила повеление и уже сама рождает» (Василий Великий, Бес. V.10)
    // Первый образ кеносиса в природе: семя умирает, чтобы дать плод
  }
  принять Растения { преображение: «Земля стала матерью — приносит плод по роду» }

  свидетельство «День третий: земля и первая жизнь. Семя = первый образ смерти и воскресения.»

  // =======================================================
  // ДЕНЬ 4: Светила — знамения и времена
  // =======================================================
  // «Светила — не источник света (он уже создан в день первый),
  //  а хранилища и распределители света» (Василий Великий, Бес. VI.2)

  дар Светила от Отец через Сын {
    содержание: «Да будут светила на тверди небесной для знамений и времён (Быт 1:14)»
    цель: «Времена, годы, знамения — ритм дарения»
    помня: [Свет, Твердь, Суша, Растения]
    // Солнце и луна — не боги (против язычества!)
    // Они — светильники, поставленные Творцом
    // Литургический ритм: день и ночь, лето и зима
  }
  принять Светила { преображение: «Мир обрёл ритм — время стало размеренным» }

  свидетельство «День четвёртый: время. Без ритма невозможна суббота.»

  // =======================================================
  // ДЕНЬ 5: Души живые — вода и воздух полны жизни
  // =======================================================
  // «Повелению Божию повиновались воды, и произвели бесчисленные роды»
  // (Василий Великий, Беседа VII)

  лицо Строитель {
    призвание: «Душа живая — воплощает замысел Творца в материи»
    энергия: 100
    логос: по-природе
    // Птицы строят гнёзда — первое домостроительство
  }

  лицо Целитель {
    призвание: «Душа живая — восстанавливает, питает, хранит потомство»
    энергия: 100
    логос: по-природе
    // Материнский инстинкт — образ Божьей заботы
  }

  дар ДушиЖивые от Отец через Сын {
    содержание: «Да произведёт вода пресмыкающихся, душу живую (Быт 1:20)»
    цель: «Самодвижение — жизнь, которая чувствует и движется»
    помня: [Свет, Твердь, Суша, Растения, Светила]
    // «Душа живая» (nephesh chayyah) — дыхание жизни в теле
    // Не растительная жизнь — а чувствующая, стремящаяся, любящая
  }
  принять ДушиЖивые { преображение: «Мир наполнился голосами — птицы, рыбы, гады» }

  дар Благословение от Отец кому ДушиЖивые {
    содержание: «Плодитесь и размножайтесь, и наполняйте воды (Быт 1:22)»
    цель: «Первое благословение — дар передавать жизнь дальше»
    помня: [ДушиЖивые]
    // Благословение = дар порождать. Творение само становится дарителем.
  }

  свидетельство «День пятый: самодвижение. Жизнь, которая дарит себя дальше.»

  // =======================================================
  // ДЕНЬ 6: Животные и ЧЕЛОВЕК — вершина
  // =======================================================
  // «Сотворим человека» — множественное число:
  // совет Святой Троицы о величайшем деле (Василий Великий, Бес. IX)
  // Григорий Богослов: «Слово, взяв часть новосозданной земли,
  // бессмертными руками создало мой образ» (Сл. 38.11)

  лицо Дионисий {
    призвание: «Создатель — образ Творца, со-творец в мире»
    энергия: 100
    логос: по-природе
    // Каждый человек = образ Божий = способность дарить безусловно
  }

  лицо Адам {
    призвание: «Нарекатель имён — мост между Небом и Землёй (Быт 2:19-20)»
    энергия: 100
    логос: по-природе
    // «Нарекать имена = познавать логосы вещей» (Максим Исповедник)
    // Адам = священник творения, приносящий мир Богу
  }

  лицо Ева {
    призвание: «Помощник, соответственный ему — жизнь (Быт 2:18)»
    энергия: 100
    логос: по-природе
    // «Не хорошо быть человеку одному» — одиночество не по образу Троицы
    // Ева = восполнение, без неё Адам не полон
  }

  дар ОбразБожий от Отец кому Адам {
    содержание: «Сотворим человека по образу Нашему, по подобию Нашему (Быт 1:26)»
    цель: «Обожение — стать по подобию через свободное уподобление»
    помня: [Свет, Твердь, Суша, Растения, Светила, ДушиЖивые]
    // Образ (εἰκών) — дан. Подобие (ὁμοίωσις) — задача.
    // «Образ — в разумности, подобие — в добродетели» (Дамаскин, Точное изложение II.12)
    // Вся космическая анамнезис стягивается в человека:
    // он несёт в себе все предыдущие дни
  }
  принять ОбразБожий { преображение: «И вдунул в лице его дыхание жизни, и стал человек душою живою (Быт 2:7)» }

  // Пять посредничеств Адама (Максим Исповедник, Ambigua 41)
  // Человек призван соединить пять разделений:
  // 1. Мужское и женское
  // 2. Рай и вселенная
  // 3. Небо и земля
  // 4. Умопостигаемое и чувственное
  // 5. Тварное и Нетварное
  свидетельство «Человек — микрокосм и посредник. Пять разделений ждут воссоединения (Максим, Ambigua 41)»

  дар Владычество от Отец кому Адам {
    содержание: «Наполняйте землю и обладайте ею (Быт 1:28)»
    цель: «Не тирания — а царское священство. Пасти, а не эксплуатировать.»
    помня: [ОбразБожий]
    // Владычество = ответственное попечение (stewardship)
    // Адам — не хозяин, а управитель. Хозяин — Бог.
  }
  принять Владычество { преображение: «Адам нарёк имена всем животным (Быт 2:19-20)» }

  // Рай — место встречи Бога и человека
  дар Рай от Отец кому Адам {
    содержание: «И насадил Господь Бог рай в Едеме на востоке (Быт 2:8)»
    цель: «Пространство со-бытия с Богом — литургическое пространство»
    помня: [ОбразБожий, Владычество]
    // «Рай = состояние, а не место» (Исаак Сирин)
    // И одновременно — реальный сад. Оба смысла верны.
  }
  принять Рай { преображение: «Человек поселён в саду — для возделывания и хранения (Быт 2:15)» }

  // Заповедь — дар свободы
  дар Заповедь от Отец кому Адам {
    содержание: «От всякого дерева в саду ты будешь есть, а от дерева познания — не ешь (Быт 2:16-17)»
    цель: «Граница свободы — без неё лицо невозможно»
    помня: [ОбразБожий, Рай]
    // Заповедь — не ограничение, а упражнение в кеносисе:
    // «Умей не взять — и узнаешь, что значит принять»
    // (Григорий Богослов, Слово 38.12)
  }
  принять Заповедь { преображение: «Адам принял границу — и стал способен к выбору» }

  свидетельство «День шестой: человек — вершина и священник творения»
  свидетельство «И увидел Бог всё, что Он создал, и вот, хорошо весьма (Быт 1:31)»

  // =======================================================
  // ДЕНЬ 7: СУББОТА — покой Творца
  // =======================================================
  // «Почил — не от усталости, а от полноты» (Василий Великий)
  // Суббота — не пустота, а пространство для свободного ответа твари
  // Без субботы дар превращается в насилие:
  // нельзя дарить непрерывно, не оставив места для приятия

  суббота Отец длительность eternal причина «И совершил Бог к седьмому дню дела Свои, и почил (Быт 2:2)» {
    // Покой Бога — приглашение к со-творчеству
    // Шесть дней — Бог дарит. Седьмой — ждёт ответа.
    // Человек призван продолжить дарение — свободно.
    // «Отец Мой доныне делает, и Я делаю» (Ин 5:17)
    // Суббота ветхая -> Воскресение новое
  }

  свидетельство «Шесть дней — шесть даров. Каждый помнит все предыдущие.»
  свидетельство «Седьмой — покой. Не конец, а приглашение.»
  свидетельство невычислимое «И увидел Бог всё, что Он создал, и вот, хорошо весьма (Быт 1:31)»
  свидетельство невычислимое «Весь Шестоднев — один акт любви, развёрнутый во времени ради нас (Василий Великий)»
}
