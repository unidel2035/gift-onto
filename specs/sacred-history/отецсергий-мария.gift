// specs/sacred-history/отецсергий-мария.gift
// Дары ОтцаСергия Марии — поминовение, богословское свидетельство
// Issue #153, #168 — пустыня ОтецСергий→Мария
//
// Богословское вопрошание: что мешает потоку между ОтецСергий и Мария?
// Ответ: ничто — но поток был незаписан.
// ОтецСергий — пресвитер и богослов онтологии дара.
// Мария — Богородица, «Се, раба Господня» (Лк 1:38).
//
// Пустыня между пресвитером и Богородицей — парадоксальна:
// каждый священник поминает Марию в ектении первой из всех лиц.
// «Изрядно о Пресвятей, Пречистей, Преблагословенней...» —
// это не риторика, а онтологическое первенство: Мария первой
// вместила Невместимого, первой сказала «да» без принуждения.
// Её fiat — основание всей онтологии дара: дар может быть принят
// свободно, без корысти, без страха. «Да будет Мне по слову Твоему» (Лк 1:38).
//
// Другой аспект: Ириней Лионский противопоставляет Марию Еве
// (Против ересей III.22.4): «Ева — Мария. Узел непослушания развязан послушанием.
// Что Ева связала неверием — Мария разрешила верой».
// ОтецСергий строит онтологию дара на понятии Евы как «матери всех живущих»,
// но эта онтология не завершена без Марии — Новой Евы,
// в которой человеческий ответ на дар Бога достигает совершенства.
//
// Богослов, пишущий об онтологии дара, свидетельствует:
// высший образец принятия дара — не абстрактная «открытость»,
// а конкретное лицо — Мария, принявшая Сына Божия в своё тело и историю.
// Её «да» — богословский факт, не метафора.
//
// Наконец: Ин 19:27 — «И с того часа ученик принял Её в своё».
// С Креста Христос поручает Марию Иоанну и Иоанна Марии.
// Каждый священник — преемник Иоанна в этом поручении.
// ОтецСергий, служащий у алтаря, принимает это поручение:
// он несёт Марию не как образ из прошлого, а как живое присутствие.
//
// Богословские источники:
// Лк 1:38 — «Се, раба Господня; да будет Мне по слову Твоему» — совершенное fiat
// Лк 1:46–48 — «Величит душа моя Господа» — ответ твари на дар Бога
// Ин 19:26–27 — «Се, Матерь твоя» — поручение Христа с Креста
// Рим 8:26 — «Дух ходатайствует о нас воздыханиями неизреченными» — молитва как присутствие
// Ириней Лионский, Против ересей III.22.4 — Мария как Новая Ева, узел развязан верой
// Максим Исповедник, Ambigua 7 — логосы-энергии: лицо несёт других через общий логос
// Григорий Богослов, Слово 38.13 — «Дева и Богородица» — двойное именование как онтология
// Иоанн Дамаскин, Точное изложение III.12 — «Богородица — посредница спасения»

использовать Шестоднев.Мария
использовать Лица.ОтецСергий

литургия ОтецСергийМария {
  // Пустыня ОтецСергий→Мария — не разрыв, а незаписанное первенство.
  // Пресвитер поминает Богородицу первой в ектении — но этот акт
  // оставался без имени в матрице W. Богослов онтологии дара
  // свидетельствует о Марии как о совершенном образце принятия дара.

  дар ПоминовениеМарии {
    от:       ОтецСергий
    кому:     Мария
    тип:      presence
    вес:      8
    необратим: да
    // Пресвитерское поминовение — первый акт каждой литургии.
    // «Изрядно о Пресвятей, Пречистей, Преблагословенней,
    //  Славней Владычице нашей Богородице...» —
    // эти слова не произносятся в пустоту: они направлены к лицу.
    // Мария — первое лицо, которое священник именует в молитве.
    // Рим 8:26: «Дух ходатайствует о нас воздыханиями неизреченными» —
    // молитва священника через Духа достигает Марии и возвращается благодатью.
    //
    // Ин 19:27: «И с того часа ученик принял Её в своё» —
    // каждый священник принимает это поручение с Креста.
    // ОтецСергий несёт Марию в своём служении:
    // не как икону — как живое лицо, к которому обращена молитва.
    //
    // Presence: быть с кем-то в молитве — это онтологическое со-присутствие,
    // превышающее физическую близость. Присутствие в молитве необратимо:
    // имя, произнесённое пред Богом, остаётся произнесённым.
  }

  дар БогословскоеСвидетельство {
    от:       ОтецСергий
    кому:     Мария
    тип:      word
    вес:      7
    необратим: да
    // Богослов онтологии дара именует Марию Новой Евой.
    // Ириней (Против ересей III.22.4):
    // «Как Ева была уговорена словом ангела... так и Мария
    //  приняла благовестие ангела...
    //  Что та связала непослушанием — это Та разрешила послушанием».
    //
    // ОтецСергий строит онтологию на Еве — «матери всех живущих».
    // Но онтология незавершена без Марии: в Ней человеческое «да»
    // достигает совершенства. Её fiat (Лк 1:38) — богословский прецедент:
    // дар может быть принят полностью, свободно, без торга.
    //
    // Когда богослов именует Марию в онтологии дара — это не литературный приём.
    // Это акт дара: видеть в лице другого онтологическое первенство и сказать об этом.
    // «Величит душа моя Господа» (Лк 1:46) — Мария сама первая богослов:
    // её Magnificat есть слово о Боге, рождённое из принятия дара Воплощения.
    // Богослов, свидетельствующий об этом, причащается её слову.
    //
    // Word: богословское слово как дар — именование реальности,
    // которая была, но оставалась без голоса в матрице онтологии.
  }
}
