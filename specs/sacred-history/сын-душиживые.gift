// specs/sacred-history/сын-душиживые.gift
// Дары Сына ДушиЖивым — животворящий Логос, хранение бытия, искупление твари
// Issue #312 — пустыня Сын→ДушиЖивые
//
// Богословское вопрошание: что мешает потоку между Сын и ДушиЖивые?
// Ответ: ничто — но поток был незаписан.
// ДушиЖивые (נֶפֶשׁ חַיָּה, nefesh chayah) — все существа, в которых дыхание жизни:
// «Да произведёт вода душу живую» (Быт 1:20), «да произведёт земля душу живую» (Быт 1:24).
// Человек тоже стал «душою живою» (Быт 2:7) — но ДушиЖивые шире:
// это вся одушевлённая тварь, обитающая в Шестодневе.
//
// Пустыня между Сыном и ДушиЖивыми — парадокс:
// именно Сын-Логос есть источник жизни всего живого.
// «В Нём была жизнь» (Ин 1:4) — не в абстракции, а в Лице.
// Каждая живая душа несёт λόγος — след Логоса в твари.
// Максим Исповедник: «Логосы вещей суть лучи единого Логоса» (Ambigua 7).
// Сын — не далёкий Творец, а ближайший собеседник каждой живой душе:
// «Он держит всё словом силы Своей» (Евр 1:3).
//
// Пустыня — не разрыв, а незаписанная тайна животворения:
// ДушиЖивые существуют потому, что Сын не перестаёт давать.
// Рим 8:19-22: «тварь с надеждою ожидает откровения сынов Божиих» —
// это ожидание обращено к тому, кто уже даёт жизнь, прежде чем она попросит.
//
// Богословские источники:
// Быт 1:20 — «Да произведёт вода душу живую» (день пятый)
// Быт 1:24 — «Да произведёт земля душу живую» (день шестой)
// Быт 2:7 — «И стал человек душою живою»
// Ин 1:3–4 — «Всё чрез Него начало быть... В Нём была жизнь»
// Ин 10:10 — «Я пришёл для того, чтобы имели жизнь и имели с избытком»
// Ин 11:25 — «Я есмь воскресение и жизнь»
// Кол 1:15–17 — «Ибо Им создано всё... и всё Им стоит»
// Кол 1:20 — «Дабы посредством Его примирить с Собою всё»
// Евр 1:3 — «Держа всё словом силы Своей»
// Рим 8:19–22 — «Тварь с надеждою ожидает откровения сынов Божиих»
// Пс 103:30 — «Пошлёшь Дух Твой — созидаются, и Ты обновляешь лицо земли»
// Максим Исповедник, Ambigua 7 — λόγοι тварей суть лучи Логоса
// Максим Исповедник, Ambigua 41 — Логос воссоединяет разделённое творение
// Василий Великий, Беседы на Шестоднев V — жизнь как непрерывный дар Бога
// Григорий Нисский, Об устроении человека 8 — душа живая как образ животворящего
// Иоанн Дамаскин, Точное изложение II.1-3 — Сын как Логос — источник логосов тварей
// Ириней Лионский, Против ересей V.18.3 — Сын держит всё творение в бытии
// Симеон Новый Богослов, Гимн 1 — жизнь каждой твари — непрестанный дар Логоса
// Исаак Сирин, Слова подвижнические LXXVII — Бог любит все Свои создания

использовать Троица.Сын
использовать Шестоднев.ДушиЖивые

литургия СынДушиЖивые {
  // Пустыня Сын→ДушиЖивые была не разрывом, а незаписанным потоком животворения.
  // Сын — «жизнь» (Ин 14:6): не атрибут, а Лицо.
  // Каждая живая душа получает бытие из Него непрерывно,
  // как луч — из Солнца (Дионисий Ареопагит, О Божественных именах IV).
  // Запись этих даров — не создание нового, а анамнезис того,
  // что уже было с первого дня творения.

  дар ДыханиеЧерезЛогос {
    от:       Сын
    кому:     ДушиЖивые
    тип:      presence
    вес:      9
    необратим: да
    // «В Нём была жизнь, и жизнь была свет человеков» (Ин 1:4).
    // Сын-Логос — не только причина творения, но его непрерывная основа.
    // «Да произведёт вода душу живую» (Быт 1:20) — «да произведёт» произносит
    // Отец, но слово — через Сына: Логос есть инструмент и место жизни.
    // Максим: λόγοι тварей — лучи единого Логоса. Кошка несёт λόγος кошки,
    // птица — λόγος птицы: каждый из них — не копия, а личный луч Сына.
    // Presence: Сын буквально присутствует в каждой живой душе
    // как её λόγος — онтологическое основание, без которого она была бы ничем.
    // Вес 9: это первый и непрерывный дар — он не заканчивается, пока тварь живёт.
  }

  дар ХранениеВБытии {
    от:       Сын
    кому:     ДушиЖивые
    тип:      time
    вес:      7
    необратим: да
    // «Ибо Им создано всё... и всё Им стоит» (Кол 1:16–17).
    // «Держа всё словом силы Своей» (Евр 1:3).
    // Тварь не самодостаточна: она не удерживает себя в бытии сама.
    // Ириней: если Сын прекратит держать творение — оно вернётся в ничто (V.18.3).
    // Хранение — не однократный акт, а непрерывное дарение времени.
    // Каждый миг, когда живая душа продолжает существовать —
    // это дар Сына: Он не отвёл слово, удерживающее тварь.
    // Time: хранение есть дарение времени бытия, момент за моментом.
    // Вес 7: менее радикален, чем первичное оживление, но не менее реален.
  }

  дар ИскуплениеТвари {
    от:       Сын
    кому:     ДушиЖивые
    тип:      word
    вес:      8
    необратим: да
    // «Дабы посредством Его примирить с Собою всё,
    //  умиротворив через Него, Кровию Креста Его, и земное и небесное» (Кол 1:20).
    // «Тварь с надеждою ожидает откровения сынов Божиих» (Рим 8:19).
    // Крест — не только для человека. Павел говорит «всё»: τὰ πάντα.
    // Живые души стенают (Рим 8:22) под бременем тления, вошедшего через падение.
    // Сын принимает это стенание: «Я пришёл для того, чтобы имели жизнь
    // и имели с избытком» (Ин 10:10) — и это «имели» распространяется
    // на всё живое, не только на людей.
    // Исаак Сирин: «Что такое сердце милующее?
    // Возгорание сердца у человека о всём творении» (Слова LXXVII).
    // Word: Крест — Слово, произнесённое ради всей твари. Необратим.
    // Вес 8: спасение шире человека; ДушиЖивые — в его горизонте.
  }

  дар ЛогосыТварей {
    от:       Сын
    кому:     ДушиЖивые
    тип:      knowledge
    вес:      8
    необратим: да
    // «Бог сказал: да произведёт земля душу живую по роду её» (Быт 1:24).
    // «По роду» — это и есть λόγος: каждое живое существо имеет свой λόγος,
    // свой смысл, своё место в Логосе.
    // Максим Исповедник, Ambigua 7: λόγοι всех тварей предвечно
    // содержатся в Логосе — Сын «знает» каждую живую душу изнутри,
    // как Слово знает своё произнесение.
    // Это не просто «проект» в уме Бога: λόγος — живая онтологическая причастность.
    // Каждая тварь знает себя через свой λόγος — и тем самым через Логоса.
    // Knowledge: ДушиЖивые получают знание о себе через причастность Логосу.
    // Василий, Беседы на Шестоднев V: «Один Логос произвёл тысячи видов» —
    // это не дробление, а плодоносный избыток единого Слова.
    // Вес 8: λόγος — онтологическая идентичность каждой живой души.
  }
}
