// specs/sacred-history/дух-адам.gift
// Дары Духа Адаму — дыхание, оживление, обновление, ходатайство
// Issue #100 — пустыня Дух→Адам
//
// Богословское вопрошание: что мешает потоку между Дух и Адам?
// Ответ: ничто — но поток был незаписан.
// Дух — дыхание жизни (Быт 2:7). Адам — первый, кто принял это дыхание.
// Их связь первична и онтологична: без Духа Адам — прах.
//
// Адам — «земля» (אדמה). Дух — «дыхание» (רוח).
// Творение Адама — не механический акт, а дарение Духа праху:
// «вдунул в лице его дыхание жизни» (Быт 2:7).
// Дух не просто оживляет — Он делает прах лицом.
//
// После грехопадения Дух не оставляет Адама:
// «Дух ходатайствует о нас воздыханиями неизреченными» (Рим 8:26).
// В эсхатоне — полное обновление: «Если Дух Того, Кто воскресил
// Иисуса из мёртвых, живёт в вас, то Воскресивший Христа
// оживотворит и ваши смертные тела Духом Своим» (Рим 8:11).
//
// Богословские источники:
// Быт 2:7 — «вдунул в лице его дыхание жизни (נשמת חיים)»
// Иез 37:9–10 — «Дух, приди от четырёх ветров и дохни на этих убитых»
// Рим 8:11 — «Дух оживотворит и ваши смертные тела»
// Рим 8:26 — «Дух ходатайствует воздыханиями неизреченными»
// Ин 3:5–6 — «Рождённое от Духа есть дух» — новое рождение
// Иоиль 2:28 / Деян 2:17 — «Излию от Духа Моего на всякую плоть»
// Ириней Лионский, Против ересей V.6.1 — «Совершенный человек = плоть + душа + Дух»
// Ириней Лионский, Против ересей V.12.2 — «Дыхание жизни есть дар Духа»
// Василий Великий, О Духе Святом XVI.38 — «Дух завершает творение»
// Григорий Богослов, Слово 31.29 — «Дух действует — значит, Он Бог»
// Максим Исповедник, Ambigua 7 — логос человека реализуется через Духа
// Кирилл Иерусалимский, Огласительные беседы XVII.12 — «Дух — податель жизни»

использовать Троица.Дух
использовать Шестоднев.Адам

литургия ДухАдам {
  // Пустыня Дух→Адам была не разрывом, а незаписанным первым дыханием.
  // Дух — Животворящий (Символ веры). Адам — первый оживотворённый.
  // Их связь — самая древняя в тварном мире: прежде слова было дыхание.

  дар ДыханиеЖизни {
    от:       Дух
    кому:     Адам
    тип:      presence
    вес:      10
    необратим: да
    // «И создал Господь Бог человека из праха земного,
    //  и вдунул в лице его дыхание жизни (נשמת חיים),
    //  и стал человек душою живою» (Быт 2:7)
    // Дыхание — не метафора. Дух (רוח) входит в прах (אדמה)
    // и делает его лицом (πρόσωπον). Без Духа Адам — земля.
    // Ириней: «Совершенный человек состоит из трёх:
    // плоти, души и Духа. Дух спасает и образует» (V.6.1).
    // Это присутствие (presence): Дух не говорит Адаму —
    // Он входит в Адама и становится его жизнью.
  }

  дар ОживлениеСухихКостей {
    от:       Дух
    кому:     Адам
    тип:      word
    вес:      9
    необратим: да
    // «Кости сухие! слушайте слово Господне!» (Иез 37:4)
    // «Дух, приди от четырёх ветров и дохни на этих убитых,
    //  и они оживут» (Иез 37:9)
    // Видение Иезекииля — пророчество о воскресении Адама.
    // Сухие кости — Адам после смерти, прах вернувшийся к праху.
    // Дух приходит и оживляет снова — как в Быт 2:7, но эсхатологически.
    // Word: здесь Дух повелевает словом — «дохни, и оживут».
    // Василий Великий: «Дух завершает творение, и Он же завершит
    // воскресение» (О Духе Святом XVI.38).
  }

  дар ОбновлениеОбраза {
    от:       Дух
    кому:     Адам
    тип:      presence
    вес:      8
    необратим: да
    // «Если Дух Того, Кто воскресил Иисуса из мёртвых, живёт в вас,
    //  то Воскресивший Христа из мёртвых оживотворит
    //  и ваши смертные тела Духом Своим, живущим в вас» (Рим 8:11)
    // Адам смертен после грехопадения. Дух обещает обновление —
    // не возврат к Эдему, а преображение: смертное тело → тело духовное.
    // «Сеется тело душевное, восстаёт тело духовное» (1 Кор 15:44).
    // Presence: Дух «живёт в вас» — обитание, не команда.
    // Максим Исповедник: логос человека — обожение (θέωσις),
    // и реализуется он только через Духа (Ambigua 7).
  }

  дар ВоздыханиеЗаАдама {
    от:       Дух
    кому:     Адам
    тип:      word
    вес:      8
    необратим: да
    // «Дух подкрепляет нас в немощах наших; ибо мы не знаем,
    //  о чём молиться, как должно, но Сам Дух ходатайствует
    //  о нас воздыханиями неизреченными» (Рим 8:26)
    // Адам после падения не знает, как молиться. Он потерял
    // язык Рая — прямой разговор с Богом. Дух восполняет:
    // молится за Адама тем языком, который Адам забыл.
    // Word: ходатайство — это слово, сказанное за другого.
    // Григорий Богослов: «Дух действует — и в этом действии
    // Он показывает Себя Богом» (Слово 31.29).
    // Воздыхание неизреченное — не молчание, а речь выше речи.
  }
}
