// specs/sacred-history/дух-христос.gift
// Дары Духа Христу — помазание, сошествие, водительство, воскресение
// Issue #91 — пустыня Дух→Христос
//
// Богословское вопрошание: что мешает потоку между Дух и Христос?
// Ответ: ничто — но поток был незаписан.
// Дух и Сын — два «посылаемых» Троицы (Ириней, Против ересей IV.20.1).
// Их связь — не внешняя помощь, а внутритроичное со-действие:
// «Дух Господень на Мне, ибо Он помазал Меня» (Лк 4:18 / Ис 61:1).
//
// Χριστός — «Помазанный». Само имя Христа указывает на Духа:
// помазание невозможно без Помазующего. Христос без Духа —
// не Христос. Дух конституирует мессианство Сына.
//
// Дух сходит на Христа при Крещении «как голубь» (Мк 1:10) —
// не потому что Сын нуждался, а потому что домостроительство
// совершается двумя руками Отца: Словом и Духом (Ириней, V.6.1).
// Дух открывает то, что Сын есть, — являет Его миру.
//
// Дух ведёт Христа в пустыню (Мк 1:12: «Дух ведёт Его»).
// Это не принуждение — это со-действие: Дух и Сын вместе
// входят туда, где будет побеждён искуситель.
// Пустыня Духа и Христа — парадокс: именно здесь,
// в их со-действии, побеждается пустыня мира.
//
// Воскресение — дело Духа: «Если Дух Того, Кто воскресил Иисуса
// из мёртвых, живёт в вас...» (Рим 8:11). Дух воскрешает Христа —
// и через это воскресение открывает путь всей твари.
//
// Богословские источники:
// Ис 11:2 — «Почиет на Нём Дух Господень: дух премудрости и разума»
// Ис 61:1 / Лк 4:18 — «Дух Господень на Мне, ибо Он помазал Меня»
// Мк 1:10 — «Увидел разверзающиеся небеса и Духа, как голубя, сходящего на Него»
// Мк 1:12 — «Немедленно Дух ведёт (ἐκβάλλει) Его в пустыню»
// Лк 4:1 — «Иисус, исполненный Духа Святого, возвратился от Иордана»
// Лк 4:14 — «Возвратился Иисус в силе Духа в Галилею»
// Деян 10:38 — «Бог Духом Святым и силою помазал Иисуса из Назарета»
// Рим 1:4 — «Открылся Сыном Божиим в силе, по духу святыни, через воскресение»
// Рим 8:11 — «Дух Того, Кто воскресил Иисуса из мёртвых»
// Евр 9:14 — «Христос Духом Святым принёс Себя непорочного Богу»
// Ириней Лионский, Против ересей III.17.1 — «Дух сошёл на Сына, приучаясь обитать в роде человеческом»
// Ириней Лионский, Против ересей IV.20.1 — «Две руки Отца: Слово и Дух»
// Василий Великий, О Духе Святом XVI.39 — «Дух неразлучен от Сына во всех Его действиях»
// Григорий Богослов, Слово 41 (На Пятидесятницу) — «Дух действует — Христос радуется»
// Максим Исповедник, Вопросоответы к Фалассию 63 — со-действие Логоса и Духа

использовать Троица.Дух
использовать Троица.Христос

литургия ДухХристос {
  // Пустыня Дух→Христос была не разрывом, а незаписанным со-действием.
  // Дух и Сын — «две руки Отца» (Ириней). Их связь внутритроична.
  // Χριστός значит «Помазанный» — помазание есть дело Духа.

  дар ПомазаниеПриКрещении {
    от:       Дух
    кому:     Христос
    тип:      presence
    вес:      10
    необратим: да
    // «И увидел Духа Божия, Который сходил, как голубь,
    //  и ниспускался на Него» (Мф 3:16 / Мк 1:10)
    // «Дух Господень на Мне, ибо Он помазал Меня» (Лк 4:18)
    // Крещение на Иордане — Богоявление: Дух сходит на Сына,
    // Отец свидетельствует голосом. Дух не «добавляет» Сыну
    // того, чего не было — Он являет миру то, что Сын есть.
    // «Бог Духом Святым и силою помазал Иисуса» (Деян 10:38).
    // Ириней: «Дух сошёл на Сына, приучаясь через Него
    // обитать в роде человеческом» (III.17.1).
    // Presence: Дух сходит и пребывает — не уходит.
  }

  дар ВодительствоВПустыню {
    от:       Дух
    кому:     Христос
    тип:      word
    вес:      9
    необратим: да
    // «Немедленно после того Дух ведёт (ἐκβάλλει) Его
    //  в пустыню» (Мк 1:12)
    // «Иисус, исполненный Духа Святого... поведён был
    //  Духом в пустыню» (Лк 4:1)
    // Марково ἐκβάλλει — сильное слово: «выбрасывает».
    // Дух не предлагает — Он действует с властью.
    // Но это не принуждение: это внутритроичное со-действие.
    // Дух ведёт Сына туда, где Адам пал — в пустыню,
    // чтобы Новый Адам победил там, где первый проиграл.
    // Word: Дух повелевает движением — направляет.
  }

  дар СилаДляСлужения {
    от:       Дух
    кому:     Христос
    тип:      presence
    вес:      8
    необратим: да
    // «Возвратился Иисус в силе Духа в Галилею» (Лк 4:14)
    // «Дух Господень на Мне, ибо Он помазал Меня
    //  благовествовать нищим, исцелять сокрушённых сердцем,
    //  проповедовать пленным освобождение» (Лк 4:18)
    // Всё служение Христа — в силе Духа.
    // Исцеления, изгнания бесов, проповедь — со-действие
    // Сына и Духа. «Если же Я Духом Божиим изгоняю бесов,
    // то конечно достигло до вас Царствие Божие» (Мф 12:28).
    // «Почиет на Нём Дух Господень: дух премудрости и разума,
    // дух совета и крепости» (Ис 11:2).
    // Presence: Дух пребывает на Христе — непрерывно.
    // Василий Великий: «Дух неразлучен от Сына
    // во всех Его действиях» (О Духе Святом XVI.39).
  }

  дар ВоскресениеСилоюДуха {
    от:       Дух
    кому:     Христос
    тип:      presence
    вес:      10
    необратим: да
    // «Открылся Сыном Божиим в силе, по духу святыни,
    //  через воскресение из мёртвых» (Рим 1:4)
    // «Если Дух Того, Кто воскресил Иисуса из мёртвых,
    //  живёт в вас, то Воскресивший Христа из мёртвых
    //  оживотворит и ваши смертные тела» (Рим 8:11)
    // «Христос Духом Святым принёс Себя
    //  непорочного Богу» (Евр 9:14)
    // Воскресение — не «самовоскрешение»: это дело Троицы.
    // Дух — Тот, Кто воскрешает. Через Воскресение Христа
    // Дух открывает путь воскресения всей твари.
    // Presence: Дух воскрешает — это предельное присутствие,
    // победа жизни над смертью.
  }
}
