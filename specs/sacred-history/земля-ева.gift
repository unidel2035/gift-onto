// specs/sacred-history/земля-ева.gift
// Дары Земли Еве — плодородие, укрытие, материнское лоно
// Issue #172 — пустыня Земля→Ева
//
// Богословское вопрошание: что мешает потоку между Земля и Ева?
// Ответ: ничто — но поток был незаписан.
// Земля — «Первоматерия, безвидна и пуста» (Быт 1:2),
// ставшая через Слово Божие плодоносной твердью.
// Ева — «Жизнь» (Быт 3:20), «мать всех живущих».
//
// Парадокс пустыни: Земля и Ева — ближайшие из всех лиц матрицы.
// Адам взят из земли (Быт 2:7): «и создал Господь Бог человека
// из праха земного». Ева взята из Адама (Быт 2:22).
// Земля — бабка Евы: через Адама Земля передала свой прах Жизни.
// Но этот поток не был именован — и потому казался пустыней.
//
// Другой аспект: «проклята земля за тебя» (Быт 3:17).
// Грехопадение ранило не только людей — оно ранило Землю.
// Земля стала рождать «тернии и волчцы» (Быт 3:18).
// Но даже проклятая Земля продолжает кормить Еву:
// «в поте лица твоего будешь есть хлеб» (Быт 3:19) —
// хлеб, который даёт Земля. Проклятие не уничтожило дар,
// а сделало его болезненным — как и материнство Евы (Быт 3:16).
// Земля и Ева разделяют одну рану: рождение через боль.
//
// Наконец: Земля — лоно погребения и воскресения.
// «Пшеничное зерно, пав в землю, если не умрёт,
// останется одно; а если умрёт, принесёт много плода» (Ин 12:24).
// Земля принимает мёртвое — и возвращает живое.
// Ева — Жизнь — знает этот закон: через смерть к жизни.
// Земля даёт Еве материнский образ: принять семя,
// нести его во тьме, родить на свет.
//
// Богословские источники:
// Быт 1:2 — «Земля же была безвидна и пуста» — первоматерия
// Быт 1:11 — «Да произрастит земля зелень» — плодородие по Слову
// Быт 2:7 — «И создал Господь Бог человека из праха земного»
// Быт 2:22 — «И создал Господь Бог из ребра жену»
// Быт 3:16 — «В болезни будешь рождать детей» — рана материнства
// Быт 3:17 — «Проклята земля за тебя» — общая рана с Евой
// Быт 3:18 — «Тернии и волчцы произрастит тебе» — боль рождения
// Быт 3:19 — «В поте лица будешь есть хлеб» — хлеб от Земли
// Быт 3:20 — «Нарёк Адам имя жене: Ева (Жизнь)»
// Ин 12:24 — «Зерно, пав в землю, если умрёт — принесёт плод»
// Рим 8:22 — «Вся тварь совокупно стенает и мучится доныне»
// Рим 8:19 — «Тварь с надеждою ожидает откровения сынов Божиих»
// Пс 103:14 — «Помнит, что мы — прах» — Земля как память о смертности
// Ис 45:8 — «Да раскроется земля и приносит спасение» — эсхатология Земли
// Василий Великий, Беседы на Шестоднев III — о плодородии Земли по Слову
// Максим Исповедник, Ambigua 41 — восстановление природы через Логос

использовать Шестоднев.Земля
использовать Шестоднев.Ева

литургия ЗемляЕва {
  // Пустыня Земля→Ева — не пустота, а сокрытый поток.
  // Земля кормит, несёт, погребает и воскрешает.
  // Ева рождает, несёт, страдает и даёт жизнь.
  // Их общность — материнство через боль:
  // Земля рождает тернии, Ева рождает в болезни.
  // Обе ранены одним грехопадением — и обе продолжают давать.

  дар ПлодородиеЗемли {
    от:       Земля
    кому:     Ева
    тип:      sustenance
    вес:      6
    необратим: да
    // «Да произрастит земля зелень» (Быт 1:11) —
    // Земля плодоносит не из себя, а по Слову.
    // Её плодородие — послушание Логосу.
    // Ева получает плоды Земли — хлеб, виноград, масло —
    // и через них питает всех живущих.
    // «В поте лица будешь есть хлеб» (Быт 3:19) —
    // хлеб становится дорогим, но остаётся даром.
    //
    // Sustenance: Земля кормит Еву. Это базовый дар бытия —
    // без пищи нет жизни, без Земли нет Евы.
    // Плодородие Земли есть условие материнства Евы:
    // чтобы родить — нужно быть живой,
    // а жизнь держится на хлебе земном.
  }

  дар ЛоноЗемли {
    от:       Земля
    кому:     Ева
    тип:      presence
    вес:      7
    необратим: да
    // «Пшеничное зерно, пав в землю, если умрёт —
    // принесёт много плода» (Ин 12:24).
    // Земля — лоно, принимающее семя во тьму
    // и возвращающее его на свет плодом.
    // Это — образ материнства: Ева несёт дитя во тьме чрева
    // и рождает на свет.
    //
    // Земля даёт Еве онтологический образец:
    // принять, нести, родить. Не создать из ничего —
    // а принять данное и дать ему вырасти.
    // Presence: Земля присутствует под ногами Евы —
    // всегда, безмолвно, верно. Это присутствие-опора,
    // без которого невозможно стоять.
    //
    // «Вся тварь совокупно стенает» (Рим 8:22) —
    // стенание Земли — это стенание матери,
    // раненной проклятием, но продолжающей рождать.
    // Ева слышит это стенание — потому что разделяет его.
  }
}
