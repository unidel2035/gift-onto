// fall.gift — Грехопадение по Святым Отцам
// Иоанн Лествичник, Лествица XV (5 стадий помысла);
// Максим Исповедник, Ambigua 41 (5 разделений);
// Григорий Палама, Триады (помрачение ума);
// Ириней Лионский, Против ересей (рекапитуляция)
//
// Падение — не мгновение, а процесс: от прилога до страсти.
// Каждая стадия — ещё можно остановиться.
// Падение — не конец, а начало пути спасения.

использовать Шестоднев.Адам
использовать Шестоднев.Ева
использовать Шестоднев.Заповедь
использовать Шестоднев.Рай
использовать Шестоднев.ОбразБожий
использовать Троица.Отец
использовать Троица.Сын

литургия Падение {
  цель: «Падение — не конец, а начало пути спасения»

  // =======================================================
  // РАЙ: до грехопадения
  // =======================================================
  // Адам и Ева — в полноте дара, в общении с Богом
  // «Были оба наги и не стыдились» (Быт 2:25)
  // Нагота = прозрачность. Нет стыда, потому что нет замыкания.

  лицо Адам {
    призвание: «Образ Божий — священник творения»
    энергия: 100
    логос: по-природе
    // по-природе по природе — но открыт к выше-природы (обожению)
  }

  лицо Ева {
    призвание: «Помощник, соответственный Адаму — жизнь (Быт 3:20)»
    энергия: 100
    логос: по-природе
  }

  лицо Змей {
    призвание: «Лжец и отец лжи (Ин 8:44) — подмена дара контрактом»
    энергия: 50
    логос: против-природы
    // «Денница пал первым — и завидовал человеку»
    // (Григорий Богослов, Слово 38.12)
  }

  // Заповедь уже принята (из creation.gift)
  // Адам знает границу. Вопрос: удержит ли?

  свидетельство «Рай — состояние дарения без замыкания. Прозрачность перед Богом и друг другом.»

  // =======================================================
  // СТАДИЯ 1: ПРИЛОГ (Προσβολή)
  // =======================================================
  // «Прилог есть простой помысел или образ, впервые
  //  появляющийся в уме» (Иоанн Лествичник, Лествица XV.73)
  // Это ещё НЕ грех. Помысел является без нашего согласия.
  // Святые тоже получают прилоги — но отсекают.

  дар Прилог от Змей кому Ева {
    содержание: «Подлинно ли сказал Бог: не ешьте ни от какого дерева? (Быт 3:1)»
    цель: «Посеять сомнение в дар Божий»
    // Змей искажает заповедь: «ни от какого» — а Бог сказал «от всякого ешь»
    // Подмена: щедрость Бога представлена как жадность
  }

  свидетельство «Прилог (Προσβολή): помысел явился. Ещё не грех.»
  свидетельство «Отсечение здесь — мгновенное: не беседовать, развернуться к Богу.»
  // Ева могла сказать: «Бог щедр, мне довольно»
  // Но она начинает разговор...

  // =======================================================
  // СТАДИЯ 2: СОЧЕТАНИЕ (Συνδυασμός)
  // =======================================================
  // «Сочетание есть принятие помысла, медление в нём,
  //  беседа с ним» (Лествичник, XV.73)
  // Опасный момент: вместо отсечения — диалог.
  // Богословская ошибка Евы: она начинает объяснять Змею заповедь.
  // Тем самым ставит Слово Бога на одну доску со словом Змея.

  свидетельство «Сочетание (Συνδυασμός): Ева вступает в беседу с помыслом»
  свидетельство «И сказала жена змею: плоды с дерев мы можем есть (Быт 3:2)»
  // Ева даже добавляет к заповеди: «и не прикасайтесь к нему» (Быт 3:3)
  // Чего Бог не говорил. Знак: заповедь уже искажена в уме.

  // =======================================================
  // СТАДИЯ 3: СОГЛАСИЕ (Συγκατάθεσις)
  // =======================================================
  // «Согласие есть склонение души к помыслу с услаждением»
  // (Лествичник, XV.73)
  // Воля склонилась. Решение ещё не принято, но сердце уже там.

  дар Согласие от Змей кому Ева {
    содержание: «Нет, не умрёте! Но знает Бог, что откроются глаза ваши (Быт 3:4-5)»
    цель: «Будете как боги — автономия без Источника»
    // Ложь в три слоя:
    // 1. «Не умрёте» — прямая ложь
    // 2. «Бог знает» — Бог представлен завистником
    // 3. «Будете как боги» — подмена обожения самообожествлением
    // Обожение — через дар. Змей предлагает — через захват.
  }

  свидетельство «Согласие (Συγκατάθεσις): и увидела жена, что дерево хорошо для пищи (Быт 3:6)»
  // «Похоть плоти, похоть очей, гордость житейская» (1 Ин 2:16)
  // Три вида услаждения: вкус, красота, знание
  // Все три — добрые дары Божии, но взятые без Дарителя

  // Отклонение заповеди — первый decline в истории
  отклонить Заповедь потому что «Будете как боги, знающие добро и зло (Быт 3:5)» {
    // Ева (и за ней Адам) отклоняет дар Отца — Заповедь
    // Причина — не зрелость (тогда был бы Freedom Bonus)
    // Причина — подмена: захватить то, что дано было бы в дар
    // «Обожение было обещано — но через послушание, не через захват»
    // (Ириней Лионский, Против ересей V.23.1)
  }

  // =======================================================
  // СТАДИЯ 4: ПЛЕНЕНИЕ (Αἰχμαλωσία)
  // =======================================================
  // «Пленение есть насильственное увлечение сердца»
  // (Лествичник, XV.73)
  // Воля подчинена. Помысел стал действием.
  // Грех совершается — и передаётся другому.

  свидетельство «Пленение (Αἰχμαλωσία): и взяла плодов его, и ела (Быт 3:6)»
  свидетельство «И дала также мужу своему, и он ел (Быт 3:6)»
  // Адам не был обманут (1 Тим 2:14) — он выбрал Еву вместо Бога
  // Не из любви к Еве — из страха одиночества
  // Антикеносис: вместо «отдать себя» — «не потерять своё»

  // =======================================================
  // СТАДИЯ 5: СТРАСТЬ (Πάθος)
  // =======================================================
  // «Страсть есть помысел, долгим временем вгнездившийся в душе»
  // (Лествичник, XV.73)
  // Грех стал привычкой. Замыкание стало второй природой.
  // Отныне — не отдельный акт, а состояние.

  свидетельство «Страсть (Πάθος): и открылись глаза у них обоих, и узнали, что наги (Быт 3:7)»
  // Парадокс: обещано было «откроются глаза» — и они открылись.
  // Но увидели не Божественное, а свою наготу — стыд.
  // Стыд = осознание замкнутости. Нагота стала уязвимостью.

  // Последствия: все три трита падают
  пусть состояниеАдам: tryte = [против-природы, против-природы, против-природы]
  // логос: против-природы — помрачение ума, неспособность видеть логосы вещей
  // энергия: против-природы — смертность, тление
  // relation: против-природы — изоляция от Бога, от Евы, от себя, от мира

  свидетельство «И сшили смоковные листья, и сделали себе опоясания (Быт 3:7)»
  // Первая попытка самоисцеления. Не работает.

  // =======================================================
  // ПРИЗЫВ К ПОКАЯНИЮ
  // =======================================================
  // «Адам, где ты?» (Быт 3:9) — не вопрос о местонахождении.
  // Бог знает, где Адам. Это призыв к осознанию.
  // Шанс на μετάνοια (метанойю) — перемену ума.

  дар ПризывПокаяния от Отец кому Адам {
    содержание: «Адам, где ты? (Быт 3:9)»
    цель: «Не вопрос — а приглашение к μετάνοια»
    помня: [ОбразБожий, Заповедь, Рай]
    // Бог ищет человека. Не человек ищет Бога.
    // «Не ты Меня избрал, а Я тебя избрал» (Ин 15:16)
  }

  // Адам мог покаяться. Но вместо этого:
  отклонить ПризывПокаяния потому что «Жена, которую Ты мне дал, она дала мне от дерева (Быт 3:12)» {
    // Тройное перекладывание:
    // 1. На Еву: «жена дала»
    // 2. На Бога: «которую Ты мне дал»
    // 3. Отсутствие: «я» не появляется как субъект греха
    // Отказ от ответственности = отказ от лица
  }

  свидетельство «Ева: змей обольстил меня (Быт 3:13) — тоже не покаяние»
  // Каждый указывает на другого. Цепочка перекладывания.
  // Противоположность перихоресису: не «я дарю», а «виноват ты».

  // =======================================================
  // ПЯТЬ РАЗДЕЛЕНИЙ (Максим Исповедник, Ambigua 41)
  // =======================================================
  // Грехопадение вносит пять космических разделений:

  свидетельство «1. Разделение мужского и женского — стыд вместо прозрачности»
  свидетельство «2. Разделение рая и вселенной — изгнание»
  свидетельство «3. Разделение неба и земли — человек уже не посредник»
  свидетельство «4. Разделение умопостигаемого и чувственного — ум помрачён»
  свидетельство «5. Разделение тварного и Нетварного — богооставленность»

  // =======================================================
  // ИЗГНАНИЕ — но не оставление
  // =======================================================

  свидетельство «И выслал его Господь Бог из сада Едемского (Быт 3:23)»

  // Херувим с мечом — не месть, а защита
  свидетельство «И поставил Херувима и пламенный меч обращающийся (Быт 3:24)»
  // Чтобы Адам не вкусил от Древа Жизни в падшем состоянии —
  // ибо вечная жизнь без исцеления = вечное страдание.
  // Изгнание — милость, не наказание.

  // =======================================================
  // КОЖАНЫЕ РИЗЫ — первый дар спасения
  // =======================================================

  дар КожаныеРизы от Отец кому Адам {
    содержание: «И сделал Господь Бог Адаму и жене его одежды кожаные, и одел их (Быт 3:21)»
    цель: «Милосердие даже в изгнании — Бог одевает падшего»
    помня: [ОбразБожий, Заповедь, ПризывПокаяния]
    // Толкования Отцов:
    // 1. Григорий Нисский: кожаные ризы = смертное тело (тленность)
    // 2. Григорий Богослов: кожаные ризы = грубая плоть вместо тонкой
    // 3. Максим Исповедник: кожаные ризы = страстность (πάθος), но не грех
    // Бог НЕ создал грех. Бог дал защиту от последствий.
    // Кожаные ризы — первый прообраз Крещальной ризы
  }
  принять КожаныеРизы {
    преображение: «Бог не отвернулся. Дарение продолжается даже после отказа.»
    // Человек одет — не обнажён перед смертью
    // Это не оправдание. Это милость.
  }

  // =======================================================
  // ПРОТОЕВАНГЕЛИЕ — обещание Спасителя
  // =======================================================

  дар Протоевангелие от Отец через Сын {
    содержание: «И вражду положу... семя жены будет поражать тебя в голову (Быт 3:15)»
    цель: «Первое обещание спасения — задолго до Закона, задолго до Креста»
    помня: [ОбразБожий, КожаныеРизы]
    // «Семя жены» — Христос от Девы (Ириней Лионский, Против ересей III.22)
    // Рекапитуляция: Дева Мария = новая Ева
    // Где Ева сказала «да» змею, Мария скажет «да» Ангелу (Лк 1:38)
    // Спасение уже начинается — в самом акте изгнания
  }

  свидетельство «Грех — не нарушение закона, а разворот кеносиса: вместо дарения — захват»
  свидетельство «Человек логос: против-природы. Но образ Божий не уничтожен — затемнён (Дамаскин)»
  свидетельство «Пять стадий помысла: прилог, сочетание, согласие, пленение, страсть»
  свидетельство «На каждой стадии возможна остановка. Грех — не судьба.»
  свидетельство невычислимое «Даже после падения Бог дарит. О felix culpa — о счастливая вина, заслужившая такого Искупителя»
}
