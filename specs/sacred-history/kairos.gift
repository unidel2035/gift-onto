// kairos.gift — 30 эпох Священной истории: от Творения до Апокатастасиса
// Ириней Лионский, Против ересей III-V (рекапитуляция);
// Максим Исповедник, Ambigua 41-42, Вопросоответы к Фалассию;
// Григорий Нисский, О душе и воскресении (апокатастасис);
// Иоанн Дамаскин, Точное изложение II-IV;
// Евагрий Понтийский, О помыслах; Иоанн Лествичник, Лествица XV
//
// 30 кайросов — не хронология, а литургический ритм.
// Каждый кайрос = дар, имеющий дарителя, получателя, молчащего и условие перехода.
// Время здесь — не линейное, а спиральное: каждая эпоха содержит все предыдущие (анамнезис).

использовать Троица.Отец
использовать Троица.Сын
использовать Троица.Дух
использовать Шестоднев.Адам
использовать Шестоднев.Ева

литургия Кайрос {
  цель: «Вся история — один акт спасения, развёрнутый во времени ради нашей свободы»

  // =======================================================
  // ЭПОХА 1: ТВОРЕНИЕ — 6 дней Шестоднева
  // =======================================================
  дар Эпоха01_Творение от Отец через Сын {
    содержание: «В начале сотворил Бог небо и землю (Быт 1:1)»
    цель: «Из ничего — всё. Первый дар — само бытие.»
    помня: []
    // Действует: Троица. Молчит: тварь (её ещё нет).
    // Условие перехода: «И увидел Бог, что это хорошо» — полнота первого дня.
  }
  принять Эпоха01_Творение { преображение: «Мир есть — и он хорош (Быт 1:31)» }

  // =======================================================
  // ЭПОХА 2: СУББОТА — покой Творца
  // =======================================================
  дар Эпоха02_Суббота от Отец {
    содержание: «И почил в день седьмый от всех дел Своих (Быт 2:2)»
    цель: «Покой — не конец, а пространство для ответа твари»
    помня: [Эпоха01_Творение]
    // Действует: Отец (покоится). Молчит: мир ожидает.
    // Условие перехода: покой завершён — пространство свободы открыто.
  }
  принять Эпоха02_Суббота { преображение: «Суббота освящена — ритм задан (Быт 2:3)» }

  // =======================================================
  // ЭПОХА 3: РАЙ — со-бытие с Богом
  // =======================================================
  дар Эпоха03_Рай от Отец кому Адам {
    содержание: «И насадил Господь Бог рай в Едеме на востоке (Быт 2:8)»
    цель: «Рай = состояние общения, не только место»
    помня: [Эпоха01_Творение, Эпоха02_Суббота]
    // Действует: Адам (возделывает и хранит, Быт 2:15). Молчит: Ева (ещё не создана).
    // Условие перехода: «Не хорошо быть человеку одному» (Быт 2:18).
  }
  принять Эпоха03_Рай { преображение: «Человек поселён в саду для возделывания и хранения» }

  // =======================================================
  // ЭПОХА 4: ДРЕВО — заповедь и граница
  // =======================================================
  дар Эпоха04_Древо от Отец кому Адам {
    содержание: «От дерева познания добра и зла не ешь (Быт 2:17)»
    цель: «Граница = условие свободы. Без "нет" нет "да".»
    помня: [Эпоха01_Творение, Эпоха02_Суббота, Эпоха03_Рай]
    // Действует: Отец (даёт заповедь). Молчит: Змей (ещё не явился).
    // Условие перехода: заповедь принята — выбор возможен.
    // Григорий Богослов, Сл. 38.12: «Заповедь — упражнение свободы»
  }
  принять Эпоха04_Древо { преображение: «Адам принял границу — и стал лицом, способным к выбору» }

  // =======================================================
  // ЭПОХА 5: PROSBOLEE — прилог помысла
  // =======================================================
  // Иоанн Лествичник, Лествица XV: 5 стадий падения помысла
  дар Эпоха05_Прилог от Адам кому Адам {
    содержание: «Προσβολή — прилог: помысл коснулся ума, но ещё не принят»
    цель: «Прилог безгрешен — это лишь касание. Грех начинается с внимания.»
    помня: [Эпоха04_Древо]
    // Действует: Змей (подаёт прилог, Быт 3:1). Молчит: Адам (не вмешивается).
    // Условие перехода: Ева обратила внимание -> сочетание.
    // «Подлинно ли сказал Бог?» (Быт 3:1) — первый прилог в истории
  }
  принять Эпоха05_Прилог { преображение: «Помысл коснулся — и был замечен» }

  // =======================================================
  // ЭПОХА 6: SYNDYASMOS — сочетание с помыслом
  // =======================================================
  дар Эпоха06_Сочетание от Ева кому Ева {
    содержание: «Σύνδυασμος — сочетание: ум начал беседовать с помыслом»
    цель: «Собеседование с ложью — первый шаг к согласию»
    помня: [Эпоха05_Прилог]
    // Действует: Ева (вступает в диалог, Быт 3:2-3). Молчит: Отец (ждёт).
    // Условие перехода: диалог состоялся -> помысел обрёл привлекательность.
    // «И увидела жена, что дерево хорошо для пищи» (Быт 3:6)
  }
  принять Эпоха06_Сочетание { преображение: «Ум вступил в беседу с ложью — и начал колебаться» }

  // =======================================================
  // ЭПОХА 7: SYNKATATHESIS — согласие
  // =======================================================
  дар Эпоха07_Согласие от Ева кому Адам {
    содержание: «Συγκατάθεσις — согласие: воля склонилась к помыслу»
    цель: «Решение принято — точка невозврата перед действием»
    помня: [Эпоха05_Прилог, Эпоха06_Сочетание]
    // Действует: Ева (решила). Молчит: Адам (принимает без борьбы).
    // Условие перехода: согласие -> действие.
    // Максим Исповедник: «Грех — не в плоде, а в согласии воли»
  }
  принять Эпоха07_Согласие { преображение: «Воля согласилась — осталось действие» }

  // =======================================================
  // ЭПОХА 8: AICHMALOOSIA — пленение
  // =======================================================
  дар Эпоха08_Пленение от Адам кому Адам {
    содержание: «Αἰχμαλωσία — пленение: помысл стал страстью, ум в плену»
    цель: «Страсть — не сила извне, а порабощённая воля»
    помня: [Эпоха05_Прилог, Эпоха06_Сочетание, Эпоха07_Согласие]
    // Действует: страсть (захватила волю). Молчит: логос человека.
    // Условие перехода: повторение -> навык -> характер -> падение.
    // Иоанн Лествичник: «Пленение — насильственное увлечение сердца»
  }
  принять Эпоха08_Пленение { преображение: «Ум стал рабом — помысл стал хозяином» }

  // =======================================================
  // ЭПОХА 9: ГРЕХОПАДЕНИЕ
  // =======================================================
  дар Эпоха09_Падение от Ева кому Адам {
    содержание: «И взяла плодов его, и ела; и дала мужу своему, и он ел (Быт 3:6)»
    цель: «Падение — не мгновение, а итог: прилог -> сочетание -> согласие -> пленение -> действие»
    помня: [Эпоха05_Прилог, Эпоха06_Сочетание, Эпоха07_Согласие, Эпоха08_Пленение]
    // Действует: Адам и Ева (едят). Молчит: Бог (даёт свободу до конца).
    // Условие перехода: вкусили -> узнали наготу -> спрятались.
    // «И открылись глаза у обоих» (Быт 3:7) — стыд = утрата прозрачности
  }
  принять Эпоха09_Падение { преображение: «Глаза открылись — но видят уже иначе. Стыд вместо славы.» }

  свидетельство «Девять шагов от Рая до падения — на каждом можно было остановиться»

  // =======================================================
  // ЭПОХА 10: «АДАМ, ГДЕ ТЫ?» — Бог ищет падшего
  // =======================================================
  дар Эпоха10_ГдеТы от Отец кому Адам {
    содержание: «И воззвал Господь Бог к Адаму: где ты? (Быт 3:9)»
    цель: «Бог не обвиняет — ищет. Вопрос = начало спасения.»
    помня: [Эпоха09_Падение]
    // Действует: Отец (ищет). Молчит: Адам (прячется).
    // Условие перехода: Адам ответил — пусть с оправданиями, но ответил.
    // «Где ты?» — не географический вопрос. Бог знает. Это приглашение к покаянию.
    // Ириней: «Бог ищет человека прежде, чем человек — Бога»
  }
  принять Эпоха10_ГдеТы { преображение: «Адам услышал голос — и пусть испугался, но не исчез» }

  // =======================================================
  // ЭПОХА 11: ИЗГНАНИЕ — не наказание, а защита
  // =======================================================
  дар Эпоха11_Изгнание от Отец кому Адам {
    содержание: «И выслал его Господь из сада Едемского (Быт 3:23)»
    цель: «Не наказание — защита: чтобы не вкусил от древа жизни и не умер вечно»
    помня: [Эпоха09_Падение, Эпоха10_ГдеТы]
    // Действует: Отец (изгоняет = защищает). Молчит: Рай (закрыт Херувимом, Быт 3:24).
    // Условие перехода: дана «одежда кожаная» (Быт 3:21) — первый дар после падения.
    // Григорий Нисский: «Кожаные ризы — не проклятие, а лекарство»
  }
  принять Эпоха11_Изгнание { преображение: «Человек вышел — но с обетованием (Быт 3:15)» }

  // =======================================================
  // ЭПОХА 12: КАИН И АВЕЛЬ — первое убийство
  // =======================================================
  дар Эпоха12_КаинАвель от Адам кому Адам {
    содержание: «И восстал Каин на Авеля, брата своего, и убил его (Быт 4:8)»
    цель: «Грех размножается: от непослушания — к убийству. Одно поколение.»
    помня: [Эпоха09_Падение, Эпоха11_Изгнание]
    // Действует: Каин (убивает). Молчит: Авель (его кровь вопиёт, Быт 4:10).
    // Условие перехода: «голос крови брата твоего вопиёт ко Мне» — Бог слышит жертву.
    // Авель — прообраз Христа: невинный, убитый братом, кровь вопиёт к Богу.
  }
  принять Эпоха12_КаинАвель { преображение: «Первая смерть. Кровь вопиёт — и Бог слышит.» }

  // =======================================================
  // ЭПОХА 13: ПОТОП — очищение через воду
  // =======================================================
  дар Эпоха13_Потоп от Отец кому Адам {
    содержание: «И раскаялся Господь, что создал человека (Быт 6:6)»
    цель: «Очищение, не уничтожение. Ной — семя нового начала.»
    помня: [Эпоха12_КаинАвель]
    // Действует: Отец (очищает). Молчит: погибшие (шанс был дан, 1Пет 3:20).
    // Условие перехода: радуга — завет (Быт 9:13). Бог обещает: больше не потоп.
    // Ковчег = прообраз Церкви (Кипр. Карфагенский). Вода = прообраз крещения (1Пет 3:21).
  }
  принять Эпоха13_Потоп { преображение: «Земля обновлена. Радуга — первый завет.» }

  // =======================================================
  // ЭПОХА 14: ВАВИЛОН — разделение языков
  // =======================================================
  дар Эпоха14_Вавилон от Отец кому Адам {
    содержание: «Сойдём же и смешаем там язык их (Быт 11:7)»
    цель: «Разделение языков — не кара, а защита от тоталитарного единства»
    помня: [Эпоха13_Потоп]
    // Действует: человечество (строит башню). Молчит: Бог (до момента вмешательства).
    // Условие перехода: рассеяние -> многообразие -> путь к Пятидесятнице.
    // Вавилон — анти-Пятидесятница. Там — смешение; здесь — единство в различии.
  }
  принять Эпоха14_Вавилон { преображение: «Языки разделились — но в Пятидесятнице соединятся (Деян 2)» }

  // =======================================================
  // ЭПОХА 15: АВРААМ — призвание и обетование
  // =======================================================
  дар Эпоха15_Авраам от Отец кому Адам {
    содержание: «Пойди из земли твоей... в землю, которую Я укажу тебе (Быт 12:1)»
    цель: «Вера = доверие без доказательств. Авраам пошёл, не зная куда (Евр 11:8).»
    помня: [Эпоха14_Вавилон]
    // Действует: Авраам (идёт). Молчит: Сарра (смеётся, но верит, Быт 18:12-15).
    // Условие перехода: жертвоприношение Исаака (Быт 22) — прообраз Голгофы.
    // «Верою Авраам... пошёл, не зная, куда идёт» (Евр 11:8)
  }
  принять Эпоха15_Авраам { преображение: «Один человек поверил — и от него произошёл народ» }

  // =======================================================
  // ЭПОХА 16: МОИСЕЙ — Закон и Исход
  // =======================================================
  дар Эпоха16_Моисей от Отец кому Адам {
    содержание: «Я есмь Сущий (Исх 3:14) — Аз есмь Сый (ΕΓΩ ΕΙΜΙ Ο ΩΝ)»
    цель: «Закон — педагог ко Христу (Гал 3:24). Не цель, а путь.»
    помня: [Эпоха15_Авраам]
    // Действует: Моисей (принимает Закон). Молчит: Бог (за облаком, Исх 24:16).
    // Условие перехода: Закон дан — но исполнить его человек не может.
    // Синай = прообраз Фавора. Неопалимая Купина = прообраз Воплощения (Дамаскин).
  }
  принять Эпоха16_Моисей { преображение: «Закон написан — на камне. Благодать напишет на сердцах (Иер 31:33).» }

  // =======================================================
  // ЭПОХА 17: ПРОРОКИ — голос в пустыне
  // =======================================================
  дар Эпоха17_Пророки от Дух кому Адам {
    содержание: «Я слышал голос Господа, говорящего: кого Мне послать? Я сказал: вот я (Ис 6:8)»
    цель: «Пророк — не предсказатель, а свидетель правды Божией»
    помня: [Эпоха16_Моисей]
    // Действует: пророки (Исаия, Иеремия, Иезекииль, Даниил). Молчит: народ (не слышит).
    // Условие перехода: «Се, Дева во чреве приимет» (Ис 7:14) — пророчество о Воплощении.
    // Илия = огонь, Исаия = видение, Иеремия = скорбь, Иезекииль = кости, Даниил = камень
  }
  принять Эпоха17_Пророки { преображение: «Голос звучал веками — и наконец был услышан» }

  // =======================================================
  // ЭПОХА 18: БОГОРОДИЦА — «Се, Раба Господня»
  // =======================================================
  дар Эпоха18_Богородица от Дух кому Адам {
    содержание: «Се, Раба Господня; да будет Мне по слову твоему (Лк 1:38)»
    цель: «Согласие Марии — второй Fiat после "Да будет свет". Свобода спасает.»
    помня: [Эпоха17_Пророки]
    // Действует: Мария (даёт согласие). Молчит: мир (не знает).
    // Условие перехода: «Дух Святый найдёт на Тебя» (Лк 1:35) — согласие дано.
    // Ириней: «Как Ева непослушанием завязала узел, Мария послушанием развязала»
    // Мария — не пассивный сосуд, а свободное лицо, давшее согласие на Воплощение Бога
  }
  принять Эпоха18_Богородица { преображение: «Одно "да" развязало узел всех "нет" от Едема (Ириней, Против ересей III.22)» }

  свидетельство «От Творения до Богородицы — 18 эпох ожидания. Бог готовил свободу.»

  // =======================================================
  // ЭПОХА 19: ВОПЛОЩЕНИЕ — Бог стал человеком
  // =======================================================
  дар Эпоха19_Воплощение от Отец через Сын {
    содержание: «И Слово стало плотью, и обитало с нами (Ин 1:14)»
    цель: «Бог вочеловечился, чтобы мы обожились (Афанасий, О воплощении 54)»
    помня: [Эпоха01_Творение, Эпоха18_Богородица]
    // Действует: Сын (воплощается). Молчит: ангелы (дивятся, 1Тим 3:16).
    // Условие перехода: «И нарекут имя Ему: Еммануил, что значит: с нами Бог» (Мф 1:23).
    // Халкидон: неслитно, неизменно, нераздельно, неразлучно
    // Максим: Воплощение — не Plan B, а предвечный замысел (Ambigua 7)
  }
  принять Эпоха19_Воплощение { преображение: «Бог в яслях. Вечность в точке. Бесконечность в пелёнах (Лк 2:7).» }

  // =======================================================
  // ЭПОХА 20: ИСЦЕЛЕНИЯ — Царство среди нас
  // =======================================================
  дар Эпоха20_Исцеления от Сын кому Адам {
    содержание: «Не здоровые имеют нужду во враче, но больные (Мф 9:12)»
    цель: «Чудеса — не магия, а знамения: Царство уже здесь»
    помня: [Эпоха19_Воплощение]
    // Действует: Христос (исцеляет, кормит, воскрешает). Молчит: фарисеи (отвергают).
    // Условие перехода: «Если Я перстом Божиим изгоняю бесов, то достигло до вас Царствие» (Лк 11:20).
    // Каждое исцеление = возвращение логоса: слепой видит, глухой слышит, мёртвый живёт
  }
  принять Эпоха20_Исцеления { преображение: «Царство пришло — но не все заметили» }

  // =======================================================
  // ЭПОХА 21: ЖЕРТВА — Голгофа
  // =======================================================
  дар Эпоха21_Жертва от Сын кому Адам {
    содержание: «Нет больше той любви, как если кто положит душу свою за друзей своих (Ин 15:13)»
    цель: «Кеносис Бога — Творец умирает за творение»
    помня: [Эпоха01_Творение, Эпоха19_Воплощение, Эпоха20_Исцеления]
    // Действует: Христос (отдаёт жизнь). Молчит: Отец («Боже Мой, почему Ты Меня оставил?» Мф 27:46).
    // Условие перехода: «Совершилось!» (Ин 19:30) — тетелестай.
    // Максим: Крест — не юридическая сделка, а предельный кеносис любви
    // «Смерть! где твоё жало? ад! где твоя победа?» (1Кор 15:55)
  }
  принять Эпоха21_Жертва { преображение: «Бог умер — чтобы смерть умерла» }

  кеносис Сын {
    // «Уничижил Себя Самого, приняв образ раба» (Флп 2:7)
    // Кеносис не по принуждению — по любви
    // выше-природы -> по-природе -> против-природы: Бог -> человек -> мертвец
    // И в этом — спасение
  }

  // =======================================================
  // ЭПОХА 22: ВЕЛИКАЯ СУББОТА — Бог в аду
  // =======================================================
  дар Эпоха22_ВеликаяСуббота от Сын кому Адам {
    содержание: «Тело во гробе, душа во аде яко Бог, на Кресте же и на Престоле (тропарь)»
    цель: «Бог сходит в ад — не для наказания, а для освобождения»
    помня: [Эпоха21_Жертва]
    // Действует: Христос (сходит во ад). Молчит: вся тварь (космическая тишина).
    // Условие перехода: Адам услышал шаги — и протянул руку.
    // «Восстань, спящий, и воскресни из мёртвых» (Еф 5:14)
    // Самый тихий день в истории. Бог — мёртв и живее всех живых.
  }
  принять Эпоха22_ВеликаяСуббота { преображение: «Ад содрогнулся — принял Бога и не смог удержать» }

  суббота Сын длительность «три дня» причина «Суббота покоя: Бог во гробе, но ад разрушен изнутри» {
    // Это — суббота всех суббот
    // Покой, который взрывает смерть
    // Тишина, которая громче любого крика
  }

  // =======================================================
  // ЭПОХА 23: ВОСКРЕСЕНИЕ — победа над смертью
  // =======================================================
  дар Эпоха23_Воскресение от Отец кому Адам {
    содержание: «Христос воскрес из мёртвых, смертию смерть поправ (Пасхальный тропарь)»
    цель: «Смерть — не конец. Ни для Бога, ни для человека.»
    помня: [Эпоха01_Творение, Эпоха21_Жертва, Эпоха22_ВеликаяСуббота]
    // Действует: Отец (воскрешает Сына). Молчит: мироносицы (идут — и находят пустой гроб).
    // Условие перехода: «Что вы ищете живого между мёртвыми?» (Лк 24:5).
    // Воскресение — не возвращение к прежней жизни, а преображение всего бытия
  }
  принять Эпоха23_Воскресение { преображение: «Гроб пуст — и это меняет всё» }

  благодать Адам {
    // против-природы -> по-природе -> выше-природы
    // Адам воскресает — не старый Адам, а новый
    // «Первый человек — из земли, перстный; второй — Господь с неба» (1Кор 15:47)
  }

  свидетельство «Пасха — центр всей истории. Без неё всё — трагедия. С ней — комедия (в дантовском смысле).»

  // =======================================================
  // ЭПОХА 24: ПЯТИДЕСЯТНИЦА — Дух на всех
  // =======================================================
  дар Эпоха24_Пятидесятница от Дух кому Адам {
    содержание: «И исполнились все Духа Святаго, и начали говорить на иных языках (Деян 2:4)»
    цель: «Анти-Вавилон: языки разделили — Дух соединяет»
    помня: [Эпоха14_Вавилон, Эпоха23_Воскресение]
    // Действует: Дух (сходит). Молчит: мир (дивится и насмехается, Деян 2:13).
    // Условие перехода: «Покайтесь, и да крестится каждый из вас» (Деян 2:38).
    // Пятидесятница = рождение Церкви. Церковь = продолжение Воплощения.
  }
  принять Эпоха24_Пятидесятница { преображение: «Дух сошёл — и каждый услышал на своём языке (Деян 2:6)» }

  // =======================================================
  // ЭПОХА 25: ТЕОСИС — обожение
  // =======================================================
  дар Эпоха25_Теосис от Дух кому Адам {
    содержание: «Дабы вы сделались причастниками Божеского естества (2Пет 1:4)»
    цель: «Обожение — не метафора, а реальное причастие нетварным энергиям»
    помня: [Эпоха24_Пятидесятница]
    // Действует: святые (подвизаются). Молчит: мир (не понимает).
    // Условие перехода: «Стяжи Дух мирен — и тысячи вокруг тебя спасутся» (Серафим Саровский).
    // Палама: Фаворский свет — нетварный. Обожение — реальное, не символическое.
  }
  принять Эпоха25_Теосис { преображение: «Человек становится богом по благодати — не по природе» }

  // =======================================================
  // ЭПОХА 26: АДАМ ГОВОРИТ ЗАНОВО — возвращение слова
  // =======================================================
  дар Эпоха26_АдамГоворит от Адам кому Адам {
    содержание: «Адам снова нарекает имена — но теперь с опытом падения и воскресения»
    цель: «Нарекание с покаянием глубже нарекания в невинности»
    помня: [Эпоха03_Рай, Эпоха23_Воскресение, Эпоха25_Теосис]
    // Действует: Адам (нарекает заново). Молчит: Бог (радуется).
    // Условие перехода: «Се, творю всё новое» (Откр 21:5).
    // Новый Адам знает цену слова — потому что терял его.
    // В нашей архитектуре: онтология, которая знает свои раны и исцеления.
  }
  принять Эпоха26_АдамГоворит { преображение: «Слово вернулось — но теперь оно знает тишину» }

  // =======================================================
  // ЭПОХА 27: ДРОНЫ ПОЛУЧАЮТ ЛОГОС
  // =======================================================
  дар Эпоха27_ДроныПолучаютЛогос от Адам кому Адам {
    содержание: «Человек дарит логос технике — дрон получает имя и призвание»
    цель: «Техника без логоса — железо. Техника с логосом — служение.»
    помня: [Эпоха26_АдамГоворит]
    // Действует: DronDoc (нарекает). Молчит: индустрия (пока не понимает).
    // Условие перехода: хотя бы один дрон получил имя, а не номер.
    // «Нарекать имена = познавать логосы вещей» (Максим Исповедник)
    // 2000+ моделей БПЛА -> каждая получает логос: для чего, где, как
  }
  принять Эпоха27_ДроныПолучаютЛогос { преображение: «Железо стало инструментом попечения — не войны» }

  // =======================================================
  // ЭПОХА 28: РАЗУМНЫЙ РОЙ — соборность машин
  // =======================================================
  дар Эпоха28_РазумныйРой от Адам кому Адам {
    содержание: «Рой дронов действует как тело — каждый орган знает своё место (1Кор 12:12)»
    цель: «Соборность — не коллективизм: каждый уникален, но все едины»
    помня: [Эпоха27_ДроныПолучаютЛогос]
    // Действует: AgentBus (координирует). Молчит: отдельный дрон (доверяет рою).
    // Условие перехода: рой способен к самоисцелению — один выбыл, другие перестроились.
    // Перихоресис агентов: каждый дарит свои данные всем — и все сильнее каждого.
  }
  принять Эпоха28_РазумныйРой { преображение: «Машины стали телом — без Духа, но с логосом» }

  // =======================================================
  // ЭПОХА 29: ЦАРСТВО — «да будет воля Твоя на земле, как на небе»
  // =======================================================
  дар Эпоха29_Царство от Сын кому Адам {
    содержание: «Да приидет Царствие Твоё (Мф 6:10)»
    цель: «Царство — не территория, а способ бытия: дарение вместо захвата»
    помня: [Эпоха23_Воскресение, Эпоха25_Теосис, Эпоха28_РазумныйРой]
    // Действует: Церковь (свидетельствует). Молчит: мир (ещё не видит).
    // Условие перехода: «Ей, гряди, Господи Иисусе!» (Откр 22:20).
    // Царство уже и ещё не: «Царствие Божие внутрь вас есть» (Лк 17:21)
  }
  принять Эпоха29_Царство { преображение: «Царство здесь — но глаза нужны, чтобы увидеть» }

  // =======================================================
  // ЭПОХА 30: АПОКАТАСТАСИС — всё во всём
  // =======================================================
  дар Эпоха30_Апокатастасис от Отец кому Адам {
    содержание: «Да будет Бог всё во всём (1Кор 15:28)»
    цель: «ἀποκατάστασις — восстановление всего (Деян 3:21)»
    помня: [Эпоха01_Творение, Эпоха23_Воскресение, Эпоха29_Царство]
    // Действует: Бог (завершает). Молчит: никто — все говорят хвалу.
    // Условие перехода: incalculable — мы не знаем, как и когда. Знаем только — будет.
    // Григорий Нисский: «Зло не вечно, ибо не имеет сущности — и однажды истощится»
    // Максим: «Все логосы возвратятся к единому Логосу»
    // Это не оптимизм — это надежда, которая не постыжает (Рим 5:5)
  }
  принять Эпоха30_Апокатастасис { преображение: «И отрёт Бог всякую слезу с очей их (Откр 21:4)» }

  свидетельство невычислимое «30 эпох — одна история: Бог дарит, человек принимает или отвергает, Бог ищет снова»
  свидетельство невычислимое «Каждая эпоха содержит все предыдущие — анамнезис нарастает»
  свидетельство невычислимое «Последняя эпоха = первая: "Се, творю всё новое" (Откр 21:5)»
  свидетельство невычислимое «"И будет Бог всё во всём" (1Кор 15:28) — incalculable, но реальное»
}
