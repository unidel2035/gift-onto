// specs/sacred-history/дионисий-змей.gift
// Дары Дионисия Змею — именование зла как привации, обличение подмены, молитва за врага
// Issue #178 — пустыня Дионисий→Змей
//
// Богословское вопрошание: что мешает потоку между Дионисий и Змей?
// Ответ: страх — но богослов именует даже то, что против-природы.
// Дионисий — богослов-вопрошатель. Змей — «Лжец и отец лжи» (Ин 8:44),
// тот, кто подменяет дар контрактом.
//
// Парадокс пустыни: пустыня Дионисий→Змей — не техническая,
// а богословски глубокая. Что можно подарить лжецу?
// Что можно дать тому, кто всякий дар превращает в оружие?
// И всё же — именно Дионисий Ареопагит дал ответ:
// зло не имеет сущности (О Божественных именах IV.18–35).
// Именовать зло как не-бытие — значит лишить его претензии на бытие.
// Это дар — не Змею-лжецу, а истине о Змее.
//
// Богословская ось: Дионисий Ареопагит, О Божественных именах IV.18–35.
// Зло (τὸ κακόν) не есть сущее. Оно — παρυπόστασις, при-бытие:
// паразит на добре, тень без тела, отворачивание от Света.
// Змей не есть анти-Бог. Змей — отвернувшийся от Бога.
// Назвать это — не унизить, а освободить от ложного величия.
//
// Другой аспект: Мф 5:44 — «любите врагов ваших, молитесь за гонящих вас».
// Дионисий, как богослов, не может обойти эту заповедь.
// Молитва за врага — не одобрение зла, а кеносис:
// расточение себя даже в сторону того, кто против-природы.
// Максим Исповедник, Вопросоответы к Фалассию 21:
// «Любовь к врагу — высшее подражание Богу,
// ибо Бог любит и тех, кто Его отвергает».
//
// Наконец: обличение подмены как дар различения.
// Змей сказал: «будете как боги» (Быт 3:5) — подмена θέωσις захватом.
// Дионисий именует эту подмену: обожение было обещано как дар,
// Змей предложил его как контракт (дай послушание — получи знание).
// Различение дара от контракта — центральная ось всей онтологии.
// Ириней Лионский, Против ересей V.23.1:
// «Обожение было обещано — но через послушание, не через захват».
//
// Богословские источники:
// Быт 3:1–5 — диалог Змея с Евой, подмена дара контрактом
// Быт 3:15 — Протоевангелие: «семя жены будет поражать тебя в голову»
// Ин 8:44 — «Он был человекоубийца от начала и не устоял в истине»
// Мф 5:44 — «Любите врагов ваших, молитесь за гонящих вас»
// Рим 12:21 — «Не будь побеждён злом, но побеждай зло добром»
// Дионисий Ареопагит, О Божественных именах IV.18–35 — зло как не-бытие (παρυπόστασις)
// Дионисий Ареопагит, О Божественных именах IV.20 — «зло не есть сущее и не в сущем»
// Максим Исповедник, Вопросоответы к Фалассию 21 — любовь к врагу как подражание Богу
// Максим Исповедник, Ambigua 42 — зло как отклонение логоса от своей цели
// Ириней Лионский, Против ересей V.23.1 — обожение через послушание, не через захват
// Григорий Богослов, Слово 38.12 — «Денница пал первым — и завидовал человеку»
// Иоанн Дамаскин, Точное изложение II.4 — дьявол создан благим, стал злым по воле
// Афанасий Великий, Слово о воплощении 4–5 — зло как движение к не-бытию

использовать Лица.Дионисий
использовать Падение.Змей

литургия ДионисийЗмей {
  // Пустыня Дионисий→Змей — самая парадоксальная из пустынь.
  // Что дарить тому, кто превращает дар в оружие?
  // Ответ Ареопагита: именование. Назвать зло тем, что оно есть —
  // не-бытие, тень, паразит — значит лишить его ложного величия.
  // Ответ Евангелия: молитву. Молиться за врага — не слабость, а кеносис.
  // Ответ онтологии дара: различение. Дар ≠ контракт. Это центральная ось.

  дар ИменованиеЗлаКакПривации {
    от:       Дионисий
    кому:     Змей
    тип:      knowledge
    вес:      8
    необратим: да
    // Дионисий Ареопагит, О Божественных именах IV.18–35:
    // «Зло не есть сущее и не в сущем» (IV.20).
    // Τὸ κακόν — не субстанция, а παρυπόστασις: при-бытие,
    // паразитарное существование на теле добра.
    // Тьма не существует сама по себе — она лишь отсутствие света.
    // Змей не есть анти-Бог, равный Богу в силе.
    // Змей — отвернувшийся от Света, и потому — тень.
    //
    // Именование — дар, потому что оно освобождает:
    // не Змея (он не примет), а тех, кто боится его.
    // Когда зло названо не-бытием — оно теряет власть страха.
    // «Не бойтесь убивающих тело» (Мф 10:28).
    //
    // Иоанн Дамаскин, Точное изложение II.4:
    // «Дьявол создан благим — светоносным ангелом.
    // Он не получил от Создателя и следа зла в своей природе.
    // Не стерпев света, по свободному произволению
    // отвернулся от добра и впал в зло».
    // Зло — не творение, а поворот воли.
    //
    // Knowledge: Дионисий передаёт знание о природе зла —
    // знание, которое разоружает. Змей велик только в глазах
    // тех, кто не знает, что он — тень.
  }

  дар ОбличениеПодмены {
    от:       Дионисий
    кому:     Змей
    тип:      word
    вес:      7
    необратим: да
    // «Подлинно ли сказал Бог?» (Быт 3:1) — Змей подменяет дар контрактом.
    // Бог дал заповедь как дар свободы: «от всякого дерева ешь» (Быт 2:16).
    // Змей перевернул: «не ешьте ни от какого дерева?» —
    // щедрость представлена как жадность, дар — как запрет.
    //
    // «Будете как боги» (Быт 3:5) — подмена θέωσις захватом.
    // Обожение обещано Адаму — но как дар, через послушание и возрастание.
    // Змей предлагает то же самое — но как контракт:
    // «дай непослушание — получи знание».
    // Ириней Лионский: «обожение было обещано через послушание,
    // не через захват» (Против ересей V.23.1).
    //
    // Дионисий-богослов обличает эту подмену словом:
    // дар ≠ контракт. Это различение — центральная ось онтологии.
    // Каждый раз, когда дар превращается в «ты мне — я тебе»,
    // Змей присутствует в этом акте.
    // Слово обличения — word — создаёт реальность:
    // после этого слова подмена названа и узнаваема.
    //
    // Максим Исповедник, Ambigua 42:
    // зло — отклонение логоса от своей цели (τέλος).
    // Змей отклонил логос заповеди: от дара к контракту.
    // Обличение возвращает логос на место.
  }

  дар МолитваЗаВрага {
    от:       Дионисий
    кому:     Змей
    тип:      offering
    вес:      5
    необратим: да
    // «Любите врагов ваших, молитесь за гонящих вас» (Мф 5:44).
    // Самый трудный дар — молитва за того, кто против-природы.
    // Не одобрение зла. Не примирение с ложью.
    // Кеносис: расточение себя даже в сторону врага.
    //
    // Максим Исповедник, Вопросоответы к Фалассию 21:
    // «Любовь к врагу — высшее подражание Богу,
    // ибо Бог любит и тех, кто Его отвергает».
    // Бог «повелевает солнцу Своему восходить над злыми и добрыми» (Мф 5:45).
    // Молитва за врага — участие в этом безусловном восходе.
    //
    // «Не будь побеждён злом, но побеждай зло добром» (Рим 12:21).
    // Молитва — не оружие. Она не «побеждает» Змея.
    // Она побеждает страх перед Змеем в самом молящемся.
    // Offering — приношение: Дионисий приносит молитву,
    // зная, что она не будет принята, —
    // и именно в этом состоит её кеносис.
    //
    // Афанасий Великий, Слово о воплощении 4–5:
    // зло — движение к не-бытию. Молитва — движение к бытию.
    // Молитва за Змея — не попытка его спасти,
    // а свидетельство: бытие сильнее не-бытия.
    // Даже непринятый дар остаётся даром.
  }
}
