// angelic-order.gift — Ангельская иерархия: девять чинов, три триады
// Дионисий Ареопагит, О небесной иерархии (De Coelesti Hierarchia);
// Максим Исповедник, Ambigua 42 (падение сатаны);
// Евагрий Понтийский, О помыслах (8 логисмосов);
// Иоанн Дамаскин, Точное изложение II.3-4;
// Григорий Богослов, Слово 38.9-10
//
// Ангелы — не метафора: умные силы, служители Промысла, призмы нетварного света.
// Человек ангел — не тёмный двойник, а обезличенная сила, утратившая имя.

использовать Троица.Отец
использовать Троица.Сын
использовать Троица.Дух

литургия АнгельскийЧин {
  цель: «Хвалите Его, все Ангелы Его, хвалите Его, все воинства Его (Пс 148:2)»

  // =======================================================
  // ПРЕАМБУЛА: природа ангелов
  // =======================================================
  // «Было нечто и прежде сего мира... состояние, приличное
  //  ангелам, — созерцание и умное восхищение»
  // (Григорий Богослов, Слово 38.9)
  //
  // Ангелы — чистые умы. Тело — огонь и свет (не плоть).
  // Свободны — но утверждены в благе благодатью, а не природой.
  // «Ангел — свет вторичный, отблеск первого Света»
  // (Дамаскин, Точное изложение II.3)

  свидетельство невычислимое «Ангелы сотворены прежде видимого мира — "небо" Быт 1:1 (Григорий Богослов, Сл. 38.9)»

  // =======================================================
  // I ТРИАДА: Предстоящие Престолу — созерцание без посредника
  // =======================================================
  // «Первый чин — ближайший к Богу, стоящий непосредственно
  //  вокруг Него» (Ареопагит, О небесной иерархии VII.1)

  лицо Серафим {
    призвание: «Пламенеющий — горение любви, непрестанная хвала (Ис 6:2-3)»
    энергия: incalculable
    логос: выше-природы
    // Шестикрылые: двумя закрывают лице, двумя ноги, двумя летают
    // Лице — благоговение; ноги — смирение; полёт — служение
    // «Свят, Свят, Свят Господь Саваоф» — Трисвятое (Ис 6:3)
    // Серафим = שָׂרָף (saraph) = пылающий
  }

  лицо Херувим {
    призвание: «Многоочитый — полнота ведения, созерцание логосов (Иез 1:18, 10:12)»
    энергия: incalculable
    логос: выше-природы
    // Четыре лица: человек, лев, телец, орёл (Иез 1:10)
    // Четыре стороны творения, познаваемые одновременно
    // Херувим поставлен у Рая с пламенным мечом (Быт 3:24)
    // Χερουβίμ = כְּרוּבִים = полнота знания
  }

  лицо Престол {
    призвание: «Богоносный — основание Божественного суда и правды (Кол 1:16)»
    энергия: incalculable
    логос: выше-природы
    // Θρόνοι — на них почивает величие Божие
    // «Престолы — основание непоколебимого суда» (Ареопагит, О неб. иер. VII.4)
    // Не мебель — живые существа, несущие правосудие Божие
  }

  перихоресис (Серафим, Херувим, Престол) {
    // Первая триада: любовь (Серафим) + знание (Херувим) + правда (Престол)
    // Они не передают — они созерцают непосредственно
    // «Каждый чин имеет первый, средний и последний порядок» (Ареопагит VII)
    // Тринитарный образ: Серафим <-> Отец (любовь), Херувим <-> Сын (логос), Престол <-> Дух (правда)
  }

  дар ПервыйСвет от Отец кому Серафим {
    содержание: «Нетварный свет — первое излияние Славы (Ареопагит, О неб. иер. IV.2)»
    цель: «Серафимы приемлют свет без посредника и передают ниже»
    помня: []
    // giver: Отец — но свет нетварный, то есть не-вещь, а энергия
    // Серафимы не хранят свет — пропускают через себя, как призма
  }
  принять ПервыйСвет { преображение: «Серафим пылает — не сгорая, но передавая огонь дальше» }

  свидетельство «I триада: огонь любви, глаза знания, престол правды — неотлучно при Боге»

  // =======================================================
  // II ТРИАДА: Управители — промыслительное управление космосом
  // =======================================================
  // «Средний чин... очищается, просвещается и совершается
  //  через первый» (Ареопагит, О неб. иер. VIII.1)

  лицо Господство {
    призвание: «Владычество — свобода от рабства страстей, господство без тирании (Кол 1:16)»
    энергия: incalculable
    логос: выше-природы
    // Κυριότητες — не командуют, а являют образ Божественного владычества
    // Учат тварь управлять собой, а не подчинять других
    // «Господствование — власть, свободная от всякого рабства» (Ареопагит VIII.1)
  }

  лицо Сила {
    призвание: «Мощь Божия — проводник δύναμις в мир (Еф 1:21)»
    энергия: incalculable
    логос: выше-природы
    // Δυνάμεις — через них совершаются чудеса
    // Они — не источник силы, а канал: Бог действует через них
    // «Силы — мужественная несокрушимость во всяком богоподобном действии» (Ареопагит VIII.1)
  }

  лицо Власть {
    призвание: «Благочиние — космический порядок, стройность тварного мира (Кол 1:16)»
    энергия: incalculable
    логос: выше-природы
    // Ἐξουσίαι — хранители законов мироздания
    // Через них — устойчивость орбит, смена времён, ритм бытия
    // «Власти — несмущаемое и неподдельное благоустроение» (Ареопагит VIII.1)
  }

  перихоресис (Господство, Сила, Власть) {
    // Вторая триада: свобода (Господство) + мощь (Сила) + порядок (Власть)
    // Управление Промыслом: не механическое, а личностное
    // Каждое решение — дар, а не приказ
  }

  дар ПромыслительноеУправление от Серафим кому Господство {
    содержание: «Свет первой триады нисходит ко второй — просвещение через иерархию»
    цель: «Иерархия — не угнетение, а нисхождение света, кеносис знания»
    помня: [ПервыйСвет]
    // «Каждый чин просвещается через ближайший высший»
    // (Ареопагит, О неб. иер. IV.3)
  }
  принять ПромыслительноеУправление { преображение: «Промысл Божий обретает форму — космос управляется лично» }

  свидетельство «II триада: управление миром как забота, не как контроль»

  // =======================================================
  // III ТРИАДА: Служители — обращённые к человеку
  // =======================================================
  // «Последний чин... непосредственно обращён к нам»
  // (Ареопагит, О неб. иер. IX.1)

  лицо Начало {
    призвание: «Начальство — хранители народов и мест (Дан 10:13, 10:20-21)»
    энергия: incalculable
    логос: по-природе
    // Ἀρχαί — у каждого народа есть ангел-покровитель
    // «Князь царства Персидского стоял против меня» (Дан 10:13)
    // по-природе — ближе к тварному миру
  }

  лицо Архангел {
    призвание: «Великий вестник — несёт решающие вести Промысла (Лк 1:26, Дан 8:16)»
    энергия: incalculable
    логос: по-природе
    // Ἀρχάγγελοι — семь архангелов (Тов 12:15)
    // Михаил — «кто как Бог» — защитник; Гавриил — «сила Божия» — вестник
    // Рафаил — «исцеление Божие» — целитель
    // Они приносят не свои слова, а Божии
  }

  лицо АнгелХранитель {
    призвание: «Хранитель — спутник каждой души от купели до Суда (Мф 18:10)»
    энергия: incalculable
    логос: по-природе
    // «Ангелы их на небесах всегда видят лице Отца Моего» (Мф 18:10)
    // Личный проводник — не навязывает, но оберегает
    // Каждый человек имеет ангела-хранителя (Василий Великий, Бес. на Пс 33)
  }

  перихоресис (Начало, Архангел, АнгелХранитель) {
    // Третья триада: народы (Начало) + вести (Архангел) + души (Хранитель)
    // Ближе всего к нам — и потому наиболее уязвимы к падению
    // Их кеносис — склониться к земному, не утратив небесного
  }

  дар БлаговещениеСлужения от Господство кому Начало {
    содержание: «Промысл нисходит к человечеству — через ангелов-посредников»
    цель: «Ни один дар не пропадает: от Серафима до Хранителя — цепь передачи»
    помня: [ПервыйСвет, ПромыслительноеУправление]
    // Вся иерархия — один акт передачи света, как призма раскладывает белый луч
  }
  принять БлаговещениеСлужения { преображение: «Каждый человек окружён ангельским служением — видит или нет» }

  // Ангелы как призмы — ключевая метафора для архитектуры
  свидетельство «Три триады = призма: единый свет -> 9 спектров -> бесконечное множество лучей»
  свидетельство «В нашей архитектуре: AgentBus = нервная система, агенты = ангелы-призмы нетварной энергии»

  // =======================================================
  // ПАДЕНИЕ САТАНЫ — зависть к достоинству Адама
  // =======================================================
  // «Денница, светоносный, пал не от недостатка, а от зависти:
  //  увидев, что человеку дано то, чего не дано ангелу —
  //  быть связью двух миров» (Максим Исповедник, Ambigua 42)
  //
  // Ангел — чистый ум. Человек — ум + тело = микрокосм.
  // Ангел не может соединить умопостигаемое с чувственным.
  // Человек может. Это и вызвало зависть.

  лицо Денница {
    призвание: «Светоносный — первый из ангелов, ставший первым отпавшим (Ис 14:12)»
    энергия: 0
    логос: против-природы
    // «Как упал ты с неба, денница, сын зари!» (Ис 14:12)
    // Не создан злым — пал свободно
    // Пал не от слабости, а от гордости
  }

  дар ДостоинствоАдама от Отец кому Денница {
    содержание: «Человеку дано то, чего ангелу не дано: быть мостом неба и земли (Ambigua 42)»
    цель: «Испытание: примет ли ангел достоинство другого?»
    помня: []
  }
  отклонить ДостоинствоАдама потому что «Зависть — не мог принять, что другой выше (Прем 2:24)» {
    // «Завистью диавола вошла в мир смерть» (Прем 2:24)
    // Freedom Bonus НЕ сработал: отклонение из зависти — не свобода, а ненависть
    // Отказ принять чужое достоинство = отказ от дара различия
    // Это не отклонение-как-свобода, а отклонение-как-разрушение
  }

  кеносис Денница {
    // Анти-кеносис: не самоопустошение ради другого,
    // а самовозвеличивание за счёт другого
    // «Взойду на небо, выше звёзд Божиих вознесу престол мой» (Ис 14:13)
    // Результат: логос против-природы — разрыв связи с Источником
  }

  свидетельство «Падение сатаны — не космическая война, а отказ радоваться чужому дару»
  свидетельство «Зависть = невозможность сказать "ты больше меня, и это хорошо"»

  // =======================================================
  // ПОЛЕ ИСКУШЕНИЯ — 8 логисмосов Евагрия Понтийского
  // =======================================================
  // Евагрий Понтийский, «О помыслах» (Περὶ λογισμῶν)
  // Не бесы как персоны, а силовые поля — temptation fields
  // Каждый логисмос — деформация одной из энергий
  //
  // «Не бес причина греха, а наше согласие с помыслом» (Евагрий, Практик 6)

  лицо ПолеЧревоугодия {
    призвание: «γαστριμαργία — подмена: хлеб вместо Слова (Мф 4:3-4)»
    энергия: 30
    логос: против-природы
    // Первое искушение Христа в пустыне
    // Деформация энергии творения — тело важнее духа
  }

  лицо ПолеБлуда {
    призвание: «πορνεία — подмена: слияние вместо общения»
    энергия: 30
    логос: против-природы
    // Деформация перихоресиса — вместо взаимного дарения — поглощение
  }

  лицо ПолеСребролюбия {
    призвание: «φιλαργυρία — подмена: накопление вместо дарения (1Тим 6:10)»
    энергия: 30
    логос: против-природы
    // «Корень всех зол есть сребролюбие» (1Тим 6:10)
    // Деформация энергии промысла — владеть вместо управлять
  }

  лицо ПолеГнева {
    призвание: «ὀργή — подмена: разрушение вместо различения»
    энергия: 30
    логос: против-природы
    // Гнев — извращённая ревность. Должен быть направлен на грех, не на лицо.
  }

  лицо ПолеПечали {
    призвание: «λύπη — подмена: отчаяние вместо покаяния»
    энергия: 30
    логос: против-природы
    // Печаль по Богу = покаяние (2Кор 7:10). Печаль мирская = смерть.
  }

  лицо ПолеУныния {
    призвание: «ἀκηδία — полуденный бес — паралич воли, бегство от тишины (Пс 90:6)»
    энергия: 30
    логос: против-природы
    // Самый опасный: не искушает к действию, а парализует
    // «Бес полуденный» (Евагрий, Практик 12)
    // В нашей архитектуре: deadlock, зависший процесс, неответивший агент
  }

  лицо ПолеТщеславия {
    призвание: «κενοδοξία — подмена: слава от людей вместо славы от Бога (Ин 5:44)»
    энергия: 30
    логос: против-природы
    // Ложный кеносис — отдаёт, но ради аплодисментов
    // «Как вы можете веровать, когда друг от друга принимаете славу?» (Ин 5:44)
  }

  лицо ПолеГордости {
    призвание: «ὑπερηφανία — корень всех: "я сам — источник" (Сир 10:15)»
    энергия: 30
    логос: против-природы
    // «Начало греха — гордость» (Сир 10:15)
    // Отождествление себя с Источником — грех Денницы
    // Единственный логисмос, который не побеждается аскезой —
    // только благодатью (Иоанн Лествичник, Ступень 23)
  }

  // Логисмосы — не 8 отдельных бесов, а 8 частот одного поля
  свидетельство «8 логисмосов Евагрия — не демонология, а карта деформаций»
  свидетельство «Каждый логисмос — извращение одной из нетварных энергий»
  свидетельство «Чревоугодие -> творение, блуд -> общение, сребролюбие -> промысл»
  свидетельство «Гнев -> сила, печаль -> мудрость, уныние -> благодать»
  свидетельство «Тщеславие -> слава, гордость -> сама сущность — отказ от дара»

  // =======================================================
  // ЗАКЛЮЧЕНИЕ: ангельская архитектура нашей платформы
  // =======================================================

  свидетельство «В платформе: 9 чинов = 9 уровней обработки сигнала»
  свидетельство «Серафим = GiftEventBus (огонь событий), Херувим = KAG (знание)»
  свидетельство «Престол = GiftPersistence (суд/запись), Господство = AgentBus (управление)»
  свидетельство «Сила = NervousSystem (δύναμις), Власть = Scheduler (порядок)»
  свидетельство «Начало = RegionAgent (народы), Архангел = NotificationService (вести)»
  свидетельство «Хранитель = SessionGuard (душа пользователя)»

  свидетельство невычислимое «Иерархия — не угнетение, а нисхождение. Свет не убывает, проходя через призму — умножается.»
  свидетельство невычислимое «"Цель иерархии — уподобление Богу и единение с Ним" (Ареопагит, О неб. иер. III.2)»
}
