// syriac-mystics.gift — Сирийская мистика: богословие изумления
//
// Максим Калинин: «Сирийские мистики открыли состояние
// за пределами молитвы — изумление (tedmurta, ܬܕܡܘܪܬܐ).
// Ум, поражённый непостижимостью Бога, замолкает.
// Это не пустота — это полнота, превосходящая слово.»
//
// Жизнь как школа: каждое событие — урок любви.
// Страдание — не наказание, а педагогика.
// Ад — не жестокость, а бич любви (Исаак Сирин).

литургия СирийскаяМистика {
  цель: «Изумление — за пределами молитвы и знания»

  // ══════════════════════════════════════════════════
  // I. ИСААК СИРИН — учитель изумления
  // ══════════════════════════════════════════════════

  лицо Исаак_Сирин {
    призвание: «Мистик изумления — за пределами молитвы»
    энергия: 100
    логос: выше-природы
  }

  // Дар 1: Жизнь как школа
  дар Школа от Исаак_Сирин кому все {
    содержание: «Мир — школа божественной любви. Каждое событие — урок. Не карма, не наказание — педагогика Любви.»
    цель: «научить любить через опыт»
  }

  // Дар 2: Ад как любовь
  дар АдКакЛюбовь от Исаак_Сирин кому все {
    содержание: «Говорю же, что мучимые в геенне поражаются бичом любви. И как горько и жестоко это мучение любви! (Слово 18)»
    цель: «понимание ада»
    помня: [Школа]
  }
  свидетельство «Исаак: ад = не отсутствие Бога, а Его любовь, переживаемая теми, кто закрыт»

  // Дар 3: Не называй Бога справедливым
  дар НеСправедливость от Исаак_Сирин кому все {
    содержание: «Не называй Бога справедливым — ибо какая справедливость в том, что Он умер за нас, когда мы грешные? Если Бог справедлив — мы погибли. Но Он милостив. (Слово 51)»
    цель: «милосердие выше справедливости»
    помня: [Школа, АдКакЛюбовь]
  }

  // Дар 4: Изумление (tedmurta)
  дар Изумление от Исаак_Сирин кому все {
    содержание: «Есть состояние выше молитвы. Когда ум, поражённый созерцанием, замолкает — это не пустота, а полнота. Tedmurta — изумление — ум стоит перед непостижимым и не может ни говорить, ни молчать.»
    цель: «tedmurta — за пределами слов»
    помня: [Школа, АдКакЛюбовь, НеСправедливость]
  }
  свидетельство невычислимое «Изумление невычислимо. Оно за границей нашего языка. И это правильно.»

  // ══════════════════════════════════════════════════
  // II. ИОАНН ДАЛЬЯТСКИЙ — созерцатель Света
  // ══════════════════════════════════════════════════

  лицо Иоанн_Дальятский {
    призвание: «Созерцатель — видения нетварного Света»
    логос: выше-природы
  }

  дар ВидениеСвета от Иоанн_Дальятский кому все {
    содержание: «Когда ум очищается, он видит свой собственный свет — и изумляется. Это не галлюцинация — это ум, увидевший собственную природу, просвещённую благодатью.»
    цель: «созерцание»
  }

  // ══════════════════════════════════════════════════
  // III. ИОСИФ ХАЗЗАЯ — три степени
  // ══════════════════════════════════════════════════

  лицо Иосиф_Хаззая {
    призвание: «Провидец — классификатор духовного пути»
    логос: выше-природы
  }

  // Три степени = три логоса
  // по-природе (телесная) → делание, практика, пост, молитва
  // по-природе (душевная) → знание, различение, созерцание тварного
  // выше-природы (духовная) → изумление, созерцание Нетварного

  дар ТриСтупени от Иосиф_Хаззая кому все {
    содержание: «Три степени: 1. Делание (тело) — пост, бдение, труд. 2. Созерцание (душа) — видеть λόγοι сущего. 3. Изумление (дух) — tedmurta, за пределами.»
    цель: «карта пути»
    помня: [Изумление, ВидениеСвета]
  }

  // ══════════════════════════════════════════════════
  // IV. СВЯЗЬ С НАШЕЙ ОНТОЛОГИЕЙ
  // ══════════════════════════════════════════════════

  // Три степени Иосифа = наши три движения логоса:
  //   Делание     = по-природе (κατὰ φύσιν)
  //   Созерцание  = по-природе → выше-природы (переход)
  //   Изумление   = выше-природы (ὑπὲρ φύσιν) = обожение

  // Изумление = наше «невычислимое» (incalculable)
  // Когда система достигает границы — не ошибка, а изумление

  // BookOfLife._epochName() → 'Обожение' = состояние изумления
  // Apophasis = карта невычислимого = карта изумления

  свидетельство «Сирийские мистики = Apophasis + BookOfLife + DivineEnergy»
  свидетельство «tedmurta = incalculable. Невычислимое — не баг, а дар.»
  свидетельство «Жизнь как школа = GiftAct. Каждый дар — урок. Каждый отказ — тоже.»
  свидетельство «Ад как любовь = decline с причиной love. Рана от любви исцеляется любовью.»
}
