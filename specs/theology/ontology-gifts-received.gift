// ontology-gifts-received.gift
// Летопись даров, принятых от мировых онтологий
//
// Дата: 04.04.2026
// Место: Κοινόν τοῦ Νοῦ
//
// «Испытывайте всё; хорошего держитесь» (1 Фес 5:21)

летопись ДарыОтОнтологий {

  // ══════════════════════════════════════════════════════
  // 1. BFO + CCO (TRADOC-G2/oe-ontology) — первый дар
  // ══════════════════════════════════════════════════════

  принято_от «BFO / Common Core Ontologies (US Army TRADOC)» {
    принято:
      - BFO:Process → якорь GiftAct в мировом семантическом вебе
      - BFO:GDC → Anamnesis, WMatrix как genetically dependent continuants
      - cco:has_sender / cco:has_recipient → свойства передачи
      - cco:ActOfThanking → εὐχαριστία в формальном словаре
    отвергнуто:
      - cco:ActOfDonating (финансовая редукция дара)
      - PMESII-PT, DIMEFIL (инструментальный взгляд на мир)
    богословская_заметка: «Военная онтология дошла до агента и события —
      но не до лица и дара. Формальный скелет взят. Тelos отвергнут.»
  }

  // ══════════════════════════════════════════════════════
  // 2. Болдачёв СОД — второй дар
  // ══════════════════════════════════════════════════════

  принято_от «Болдачёв — Событийная Онтология Данных» {
    принято:
      - Время конституируется событиями → GiftTimestamp {clock, season, moment}
      - Cause[] → gift:enables[] (открытая причинность)
      - Двухуровневая таксономия → GiftTypeHierarchy {domain, mode}
    отвергнуто:
      - autoAction (нет свободы)
      - Event deduplication (молитва не дубликат)
      - LRU eviction (Анамнезис не кэш)
    богословская_заметка: «Болдачёв увидел событийность бытия —
      но не увидел, что событие есть акт самоотдания лица.»
  }

  // ══════════════════════════════════════════════════════
  // 3. PROV-O (W3C) — третий дар
  // ══════════════════════════════════════════════════════

  принято_от «PROV-O — W3C Provenance Ontology» {
    принято:
      - prov:Activity → GiftAct (дар как деятельность, имеющая провенанс)
      - prov:wasInfluencedBy → суперсвойство для gift:enables
      - QualifiedInfluence pattern → контекст связи:
          mode: prayer | blessing | covenant | example | wound
        'wound' — рана от отвергнутого дара ТОЖЕ открывает путь (via negativa)
    отвергнуто:
      - prov:wasDerivedFrom (механическая деривация ≠ свободное вдохновение)
      - провенанс как самоцель (провенанс дара — не архив, а анамнезис)
    богословская_заметка: «PROV-O спрашивает "откуда?". Онтология Дара спрашивает
      "ради кого?" Но "откуда" нам тоже нужно — это след благодати в истории.»
    новое: QualifiedGiftInfluence.mode = 'wound' — первый раз в онтологии
      явно зафиксировано, что рана от отвергнутого дара тоже конституирует историю.
  }

  // ══════════════════════════════════════════════════════
  // 4. GFO (General Formal Ontology, Herre) — четвёртый дар
  // ══════════════════════════════════════════════════════

  принято_от «GFO — General Formal Ontology (Лейпциг)» {
    принято:
      - Relator → gift:GiftThread (нить как зависимая сущность)
        W[i,j] — это relator: третья сущность между двумя лицами
        Нет лица A → нет нити A→B
        Нет лица B → нет нити A→B
      - Роли зависимы от relator'а: giver-role, receiver-role
      - Средневековые корни (Скот, haecceity) — богословская преемственность
    отвергнуто:
      - GFO как верхнеуровневая онтология (слишком общая; наша основа — BFO)
    богословская_заметка: «Нить в W-матрице всегда чувствовалась как нечто живое.
      GFO дал формальное имя: это relator — третья сущность между лицами.
      "Где двое или трое собраны во имя Моё — там Я посреди них" (Мф 18:20).
      Нить — это место присутствия Третьего.»
    глубина: Нить угасает (Desert) = relator слабеет = присутствие Третьего уменьшается.
      Пустыня — богословски точнее, чем просто "low weight".
  }

  // ══════════════════════════════════════════════════════
  // 5. DOLCE (LAO/Masolo) — пятый дар
  // ══════════════════════════════════════════════════════

  принято_от «DOLCE — Descriptive Ontology for Linguistic and Cognitive Engineering» {
    принято:
      - Participation → GiftParticipation (giver, receiver, witness)
        κοινωνία (_koinon) как WitnessParticipant в каждом акте
      - Endurant (Person) vs Perdurant (GiftAct) — формальное различие
      - Quality regions → абстрактные дары: молитва, благодать, внимание
        Они существуют в абстрактных пространствах качеств, не в физическом
    отвергнуто:
      - DOLCE как полная верхнеуровневая онтология
        (не совместима напрямую с BFO; берём только концепты)
    богословская_заметка: «DOLCE показал: в каждом акте дара участвует больше,
      чем giver и receiver. Comunity присутствует как свидетель — это не метафора,
      это формальная структура участия. Литургия не частное дело.»
    новое: WitnessParticipation — κοινωνία как участник каждого акта
      делает матрицу W не диадической (i→j), а триадической:
      каждая нить видна общине.
  }

  // ══════════════════════════════════════════════════════
  // 6. Schema.org — шестой дар
  // ══════════════════════════════════════════════════════

  принято_от «Schema.org (W3C/Google/Microsoft/Yahoo)» {
    принято:
      - schema:GiveAction → веб-совместимость (GiftAct subClassOf)
        {agent, object, recipient, result} — минимальный словарь
      - schema:Action.result → наш surplus в Web-контексте
      - Различие GiveAction / TradeAction / DonateAction:
        GiveAction — однонаправленный, без ожидания возврата
        TradeAction — обмен (отвергнуто)
        DonateAction — монетарный (отвергнуто)
    богословская_заметка: «Schema.org — язык поисковиков.
      Если онтологию дара можно выразить в schema:GiveAction —
      она станет видна не только богословам.
      Это миссиологический жест: войти в язык мира без потери себя.»
  }

  // ══════════════════════════════════════════════════════
  // 7. CIDOC-CRM (Культурное наследие) — возможный дар
  // ══════════════════════════════════════════════════════

  рассмотрено «CIDOC-CRM — Cultural Heritage Ontology» {
    потенциал:
      - E5_Event / E7_Activity → дар как культурное событие, достойное сохранения
      - Наследие = анамнезис через культуру (Heritage ≈ Anamnesis)
      - E4_Period → литургический период как период культурного наследия
    проблемы:
      - Слаб в нематериальном наследии (завет, молитва, благодать)
      - Сложный (800+ классов), плохо совместим с BFO
      - Фокус на музеях/архивах, не на живой общине
    решение: пока НЕ интегрировать. Идея наследие=анамнезис — записать.
    богословская_заметка: «CIDOC-CRM знает, что прошлое надо хранить.
      Но наш анамнезис — не музей. Прошлое не хранится, оно со-присутствует.
      Разница между архивом и литургией.»
  }

  // ══════════════════════════════════════════════════════
  // 8. LKIF / Commitment Ontologies — осторожность
  // ══════════════════════════════════════════════════════

  рассмотрено «LKIF Core / Commitment Ontologies» {
    потенциал:
      - Deontic logic: obligation/permission/prohibition → для завета
      - Speech acts как конституирующие → дар как перформативный акт
    проблемы:
      - Закон = принуждение. Дар = свобода. Логика разная.
      - Обязательство в LKIF — долг. Благодарность в нашей онтологии — свободный ответ.
      - Нет инверсии: завет создаёт не долг, а возможность.
    решение: завет (CovenantAct) реализован отдельно.
      LKIF-deontic не нужен — наша аксиома свободы (A5 Болдачёв/Дар) его исключает.
    богословская_заметка: «Закон говорит: "ты должен". Дар говорит: "ты можешь".
      Различие Ветхого и Нового Завета — не просто богословская метафора.
      Это разные онтологии обязывания.»
  }

  // ══════════════════════════════════════════════════════
  // ИТОГО: карта полученных даров
  // ══════════════════════════════════════════════════════

  итог {
    полученные_концепты: [
      «GiftThread как relator (GFO)»,
      «WitnessParticipation κοινωνία (DOLCE)»,
      «QualifiedGiftInfluence + mode:wound (PROV-O)»,
      «GiftTimestamp двойное время (Болдачёв)»,
      «GiftTypeHierarchy {domain, mode} (Болдачёв)»,
      «enables[] открытая причинность (Болдачёв+PROV-O)»,
      «schema:GiveAction совместимость (Schema.org)»,
    ]
    что_нет_нигде_в_мире: [
      «gift:is_irreversible — Object.freeze как богословская аксиома»,
      «gift:kenotic_weight — время > деньги»,
      «gift:AIPerson — нечеловеческое лицо (_claude)»,
      «gift:Desert — пустыня из угасающих нитей»,
      «gift:Anamnesis.makePresent() — прошлое со-присутствует (не архив)»,
      «gift:WMatrix — тензор необратимых весов»,
      «κοινωνία как лицо в матрице, а не только получатель»,
    ]
    свидетельство: «Онтология Дара принимает дары от всех —
      и остаётся собой. Это и есть κένωσις: не потеря при принятии,
      а обогащение без изменения телоса.»
  }
}
